diff --git a/frontend/lib/robotsTxt.test.ts b/frontend/lib/robotsTxt.test.ts
new file mode 100644
index 0000000..40393d8
--- /dev/null
+++ b/frontend/lib/robotsTxt.test.ts
@@ -0,0 +1,128 @@
+import { test, describe } from 'node:test';
+import assert from 'node:assert/strict';
+import fs from 'node:fs';
+import path from 'node:path';
+import { fileURLToPath } from 'node:url';
+
+const here = path.dirname(fileURLToPath(import.meta.url));
+const frontendRoot = path.join(here, '..');
+const robotsPath = path.join(frontendRoot, 'public', 'robots.txt');
+
+interface Directive { name: string; value: string; }
+
+function parseDirectives(raw: string): Directive[] {
+  return raw
+    .split('\n')
+    .map(line => line.trim())
+    .filter(line => line.length > 0)
+    .map(line => {
+      const idx = line.indexOf(':');
+      const name = line.slice(0, idx).trim();
+      const value = line.slice(idx + 1).trim();
+      return { name, value };
+    });
+}
+
+describe('T-036: frontend/public/robots.txt exists and is well-formed', () => {
+  test('robots.txt exists', () => {
+    assert.ok(fs.existsSync(robotsPath), 'frontend/public/robots.txt must exist');
+  });
+
+  const raw = fs.existsSync(robotsPath) ? fs.readFileSync(robotsPath, 'utf-8') : '';
+  const directives = parseDirectives(raw);
+
+  test('first non-empty directive is "User-agent: *"', () => {
+    assert.equal(directives[0]?.name, 'User-agent');
+    assert.equal(directives[0]?.value, '*');
+  });
+
+  test('/admin is disallowed', () => {
+    assert.ok(directives.some(d => d.name === 'Disallow' && d.value === '/admin'));
+  });
+
+  test('/dashboard is disallowed', () => {
+    assert.ok(directives.some(d => d.name === 'Disallow' && d.value === '/dashboard'));
+  });
+
+  test('/account is disallowed', () => {
+    assert.ok(directives.some(d => d.name === 'Disallow' && d.value === '/account'));
+  });
+
+  test('/api/ is disallowed', () => {
+    assert.ok(directives.some(d => d.name === 'Disallow' && d.value === '/api/'));
+  });
+
+  test('/ is allowed', () => {
+    assert.ok(directives.some(d => d.name === 'Allow' && d.value === '/'));
+  });
+
+  test('/search is not disallowed', () => {
+    const disallows = directives.filter(d => d.name === 'Disallow').map(d => d.value);
+    assert.ok(!disallows.some(v => '/search'.startsWith(v) || v === '/search'));
+  });
+
+  test('/salons is not disallowed', () => {
+    const disallows = directives.filter(d => d.name === 'Disallow').map(d => d.value);
+    assert.ok(!disallows.some(v => '/salons'.startsWith(v) || v === '/salons'));
+  });
+
+  test('/_next/ is not disallowed', () => {
+    const disallows = directives.filter(d => d.name === 'Disallow').map(d => d.value);
+    assert.ok(!disallows.some(v => '/_next/'.startsWith(v)));
+  });
+
+  test('Sitemap URL is exactly https://lookla.gr/sitemap.xml', () => {
+    assert.ok(directives.some(d => d.name === 'Sitemap' && d.value === 'https://lookla.gr/sitemap.xml'));
+  });
+
+  test('file ends with a newline', () => {
+    assert.ok(raw.endsWith('\n'), 'robots.txt must end with a trailing newline');
+    assert.ok(!raw.endsWith('\n\n'), 'robots.txt must not have a trailing blank line');
+  });
+
+  test('no conflicting "Disallow: /" exists (would block the entire site)', () => {
+    assert.ok(!directives.some(d => d.name === 'Disallow' && d.value === '/'));
+  });
+
+  test('every Disallow value for a private area is a subpath of /admin, /dashboard, /account, or /api/', () => {
+    const disallows = directives.filter(d => d.name === 'Disallow').map(d => d.value);
+    const allowedPrefixes = ['/admin', '/dashboard', '/account', '/api/'];
+    for (const v of disallows) {
+      const matchesKnownPrefix = allowedPrefixes.some(p => v === p || v.endsWith(p));
+      assert.ok(matchesKnownPrefix, `unexpected Disallow rule not tied to a known private area: ${v}`);
+    }
+  });
+
+  test('locale-prefixed private routes (en/ru/uk) are explicitly disallowed — confirmed reachable via isolated routing check', () => {
+    for (const locale of ['en', 'ru', 'uk']) {
+      for (const area of ['admin', 'dashboard', 'account']) {
+        assert.ok(
+          directives.some(d => d.name === 'Disallow' && d.value === `/${locale}/${area}`),
+          `missing Disallow: /${locale}/${area}`,
+        );
+      }
+    }
+  });
+
+  test('no /el/ locale-prefixed rules — default locale (el) is unprefixed and /el/* redirects to bare paths', () => {
+    assert.ok(!directives.some(d => d.name === 'Disallow' && d.value.startsWith('/el/')));
+  });
+
+  test('exactly one User-agent block (no duplicate robots implementation)', () => {
+    const userAgentCount = directives.filter(d => d.name === 'User-agent').length;
+    assert.equal(userAgentCount, 1);
+  });
+});
+
+describe('T-036: no duplicate robots implementation exists', () => {
+  test('no app/robots.ts dynamic route (would conflict with the static public/robots.txt)', () => {
+    const candidates = [
+      path.join(frontendRoot, 'app', 'robots.ts'),
+      path.join(frontendRoot, 'app', 'robots.tsx'),
+      path.join(frontendRoot, 'app', '[locale]', 'robots.ts'),
+    ];
+    for (const c of candidates) {
+      assert.ok(!fs.existsSync(c), `unexpected dynamic robots route found at ${c}`);
+    }
+  });
+});
