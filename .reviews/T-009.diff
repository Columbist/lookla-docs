@@ -0,0 +1,80 @@
+import { test, describe } from 'node:test';
+import assert from 'node:assert/strict';
+import fs from 'node:fs';
+import path from 'node:path';
+import { fileURLToPath } from 'node:url';
+
+const here = path.dirname(fileURLToPath(import.meta.url));
+const frontendRoot = path.join(here, '..', '..', '..', '..');
+const clientSource = fs.readFileSync(path.join(here, 'SalonDetailClient.tsx'), 'utf-8');
+
+const BANNED_KEYS = ["t('book')", "t('request')", "t('message')", 'ContactButtons'];
+const PRESERVED_KEYS = ["t('call')", "t('viber')", "t('whatsapp')", 'salon.website'];
+
+describe('T-009: no fake booking UI in salon detail', () => {
+  test('SalonDetailClient does not reference removed fake CTA translation keys', () => {
+    for (const key of BANNED_KEYS) {
+      assert.ok(!clientSource.includes(key), `SalonDetailClient.tsx must not contain "${key}"`);
+    }
+  });
+
+  test('SalonDetailClient still renders phone, viber, whatsapp, website controls', () => {
+    assert.ok(clientSource.includes("t('call')"), 'call CTA missing');
+    assert.ok(clientSource.includes("t('viber')"), 'viber CTA missing');
+    assert.ok(clientSource.includes("t('whatsapp')"), 'whatsapp CTA missing');
+    assert.ok(clientSource.includes("t('website')"), 'website CTA missing');
+  });
+
+  test('SalonDetailClient contains no empty/dead onClick booking handlers', () => {
+    // Every <button> in the CTA area must be the "show more photos" button (has onClick) —
+    // no bare, handler-less <button> should remain in the CTA block.
+    const ctaBlock = clientSource.slice(
+      clientSource.indexOf('{/* CTA buttons */}'),
+      clientSource.indexOf('{/* Description */}'),
+    );
+    assert.ok(!ctaBlock.includes('<button'), 'CTA block must contain only <a> contact links, no bare <button>');
+  });
+
+  test('ContactButtons.tsx component was deleted, not left unreachable in the tree', () => {
+    const p = path.join(frontendRoot, 'components', 'ContactButtons.tsx');
+    assert.ok(!fs.existsSync(p), 'components/ContactButtons.tsx should have been removed');
+  });
+});
+
+describe('T-009: locale files have no booking translation keys, preserve real CTAs', () => {
+  const locales = ['el', 'en', 'ru', 'uk'] as const;
+  const removedKeys = ['book', 'request', 'request_slot', 'message'];
+  const requiredKeys = ['call', 'viber', 'whatsapp', 'website', 'report'];
+
+  for (const locale of locales) {
+    test(`${locale}.json: salon namespace has no booking keys`, () => {
+      const messages = JSON.parse(
+        fs.readFileSync(path.join(frontendRoot, 'messages', `${locale}.json`), 'utf-8'),
+      );
+      for (const key of removedKeys) {
+        assert.ok(!(key in messages.salon), `${locale}.json salon.${key} should have been removed`);
+      }
+    });
+
+    test(`${locale}.json: salon namespace still has real contact CTA keys`, () => {
+      const messages = JSON.parse(
+        fs.readFileSync(path.join(frontendRoot, 'messages', `${locale}.json`), 'utf-8'),
+      );
+      for (const key of requiredKeys) {
+        assert.ok(key in messages.salon, `${locale}.json salon.${key} missing`);
+      }
+    });
+  }
+
+  test('salon namespace keys are identical across all four locales', () => {
+    const keySets = locales.map((locale) => {
+      const messages = JSON.parse(
+        fs.readFileSync(path.join(frontendRoot, 'messages', `${locale}.json`), 'utf-8'),
+      );
+      return Object.keys(messages.salon).sort();
+    });
+    for (let i = 1; i < keySets.length; i++) {
+      assert.deepEqual(keySets[i], keySets[0], `${locales[i]}.json salon keys differ from ${locales[0]}.json`);
+    }
+  });
+});
