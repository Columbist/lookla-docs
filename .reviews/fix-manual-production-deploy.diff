diff --git a/.github/workflows/deploy.yml b/.github/workflows/deploy.yml
index bc3e5e9..6d6dfea 100644
--- a/.github/workflows/deploy.yml
+++ b/.github/workflows/deploy.yml
@@ -1,11 +1,28 @@
-name: Deploy to Production
+name: Deploy Production
 
+# Manual-only (workflow_dispatch), not push-triggered — a push-triggered
+# deploy would auto-deploy production the moment DEPLOY_SSH_KEY is ever
+# added as a secret, with no review/approval step. GitHub's paid
+# "required reviewers on environment" gate isn't available on this
+# private repo's plan, so a typed confirmation input is the available
+# substitute gate. See docs/04_ARCHITECTURE/SECURITY.md and
+# IMPLEMENTATION_BACKLOG.md T-040 (deploy hardening: exact-SHA deploy,
+# pre-deploy backup, health check, rollback, deployment log).
 on:
-  push:
-    branches: [main]
+  workflow_dispatch:
+    inputs:
+      confirm:
+        description: 'Type DEPLOY to confirm production deployment'
+        required: true
+        type: string
+
+concurrency:
+  group: production-deploy
+  cancel-in-progress: false
 
 jobs:
   deploy:
+    if: github.ref == 'refs/heads/main' && inputs.confirm == 'DEPLOY'
     runs-on: ubuntu-latest
     steps:
       - name: Deploy via SSH
