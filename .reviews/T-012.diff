diff --git a/frontend/lib/reviewsSection.test.ts b/frontend/lib/reviewsSection.test.ts
new file mode 100644
index 0000000..c98a2ed
--- /dev/null
+++ b/frontend/lib/reviewsSection.test.ts
@@ -0,0 +1,86 @@
+import { test, describe } from 'node:test';
+import assert from 'node:assert/strict';
+import fs from 'node:fs';
+import path from 'node:path';
+import { fileURLToPath } from 'node:url';
+import { shouldShowReviewSourceLabel } from './reviewsSection';
+
+const here = path.dirname(fileURLToPath(import.meta.url));
+const frontendRoot = path.join(here, '..');
+
+const EXPECTED_LABELS = {
+  en: 'Source: Google Reviews / Imported: Yes / Original: No',
+  el: 'Πηγή: Google Reviews / Εισήχθη: Ναι / Πρωτότυπο: Όχι',
+  ru: 'Источник: Google Reviews / Импортировано: Да / Оригинал: Нет',
+  uk: 'Джерело: Google Reviews / Імпортовано: Так / Оригінал: Ні',
+} as const;
+
+describe('shouldShowReviewSourceLabel', () => {
+  test('hidden while loading, regardless of count', () => {
+    assert.equal(shouldShowReviewSourceLabel(true, 0), false);
+    assert.equal(shouldShowReviewSourceLabel(true, 5), false);
+  });
+
+  test('hidden when zero reviews (genuinely empty or a failed fetch collapsed to empty)', () => {
+    assert.equal(shouldShowReviewSourceLabel(false, 0), false);
+  });
+
+  test('shown once loaded with at least one review', () => {
+    assert.equal(shouldShowReviewSourceLabel(false, 1), true);
+    assert.equal(shouldShowReviewSourceLabel(false, 42), true);
+  });
+});
+
+describe('T-012: locale files define googleReviewsSourceLabel with the exact required text', () => {
+  for (const [locale, expected] of Object.entries(EXPECTED_LABELS)) {
+    test(`${locale}.json matches the exact required text`, () => {
+      const messages = JSON.parse(fs.readFileSync(path.join(frontendRoot, 'messages', `${locale}.json`), 'utf-8'));
+      assert.equal(messages.salon.googleReviewsSourceLabel, expected);
+    });
+  }
+
+  test('salon namespace key parity holds across all four locales', () => {
+    const locales = ['el', 'en', 'ru', 'uk'] as const;
+    const keySets = locales.map((locale) => {
+      const messages = JSON.parse(fs.readFileSync(path.join(frontendRoot, 'messages', `${locale}.json`), 'utf-8'));
+      return Object.keys(messages.salon).sort();
+    });
+    for (let i = 1; i < keySets.length; i++) {
+      assert.deepEqual(keySets[i], keySets[0], `${locales[i]}.json salon keys differ from ${locales[0]}.json`);
+    }
+  });
+});
+
+describe('T-012: disclosure is section-level markup, not a tooltip/title/per-review badge', () => {
+  const source = fs.readFileSync(
+    path.join(frontendRoot, 'app', '[locale]', 'salons', '[slug]', 'SalonDetailClient.tsx'),
+    'utf-8',
+  );
+
+  test('googleReviewsSourceLabel is referenced exactly once (one section-level disclosure, not per review)', () => {
+    const occurrences = (source.match(/googleReviewsSourceLabel/g) || []).length;
+    assert.equal(occurrences, 1, 'expected exactly one reference — rendered once per section, not inside the reviews.map()');
+  });
+
+  test('the label is not wrapped in a title= attribute or a collapsible/details element', () => {
+    const labelLine = source.split('\n').find((line) => line.includes('googleReviewsSourceLabel'));
+    assert.ok(labelLine, 'label line not found');
+    assert.ok(!labelLine!.includes('title='), 'must not be a title= tooltip');
+    assert.ok(!source.includes('<details') && !source.includes('<summary'), 'must not use a collapsible <details>/<summary>');
+  });
+
+  test('the label renders as a visible <p>, not inside a review card map', () => {
+    const labelLine = source.split('\n').find((line) => line.includes('googleReviewsSourceLabel'));
+    assert.ok(labelLine!.includes('<p'), 'expected a plain visible <p> element');
+  });
+
+  test('the label sits above the reviews.map() list, not below it', () => {
+    const labelIndex = source.indexOf('googleReviewsSourceLabel');
+    const mapIndex = source.indexOf('reviews.map(');
+    assert.ok(labelIndex > 0 && mapIndex > 0 && labelIndex < mapIndex, 'label must render before the review list');
+  });
+
+  test('rendering is gated by shouldShowReviewSourceLabel, not a hardcoded true', () => {
+    assert.ok(source.includes('shouldShowReviewSourceLabel(reviewsLoading, reviews.length)'));
+  });
+});
diff --git a/frontend/lib/reviewsSection.ts b/frontend/lib/reviewsSection.ts
new file mode 100644
index 0000000..1ad8c83
--- /dev/null
+++ b/frontend/lib/reviewsSection.ts
@@ -0,0 +1,11 @@
+/**
+ * T-012 (DEC-013): section-level disclosure, not per-review. Shown once
+ * reviews have actually loaded and there is at least one to show — never
+ * while still loading, and never when the count is zero (whether that's a
+ * genuinely-empty result or a failed fetch: useLazySection's error handling
+ * already collapses both to an empty array, so reviewCount === 0 covers it
+ * without inventing a separate error flag not tracked by the component).
+ */
+export function shouldShowReviewSourceLabel(loading: boolean, reviewCount: number): boolean {
+  return !loading && reviewCount > 0;
+}
