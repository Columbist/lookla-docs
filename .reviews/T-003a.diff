+"""
+T-003a: FTS GIN index — architectural verification (no DB connection required).
+
+Decision (2026-07-10): GIN index DEFERRED to T-037 (post-MVP, search consolidation).
+
+Reason:
+- The only endpoint using PostgreSQL FTS is GET /api/search (deprecated).
+- GET /api/salons is the canonical MVP endpoint and uses ILIKE, not FTS.
+- GIN index for the FTS expression is blocked by unaccent(text) STABLE volatility.
+- Creating infrastructure for a deprecated endpoint is not MVP value.
+
+These tests guard architectural invariants that matter AFTER the deferral:
+- search.py (deprecated) uses explicit regconfig in FTS functions (IMMUTABLE form).
+- The two routers use different search mechanisms (documented divergence).
+"""
+import ast
+from pathlib import Path
+
+SEARCH_ROUTER = Path(__file__).parent.parent / "app" / "routers" / "search.py"
+
+
+def test_search_router_exists():
+    assert SEARCH_ROUTER.exists(), "app/routers/search.py not found"
+
+
+def test_search_uses_to_tsvector_with_explicit_regconfig():
+    """search.py must call to_tsvector with explicit regconfig.
+
+    to_tsvector(text) is STABLE; to_tsvector(regconfig, text) is IMMUTABLE.
+    Explicit form is required if a GIN index is ever created (T-037).
+    """
+    src = SEARCH_ROUTER.read_text()
+    assert "to_tsvector('simple'," in src or 'to_tsvector("simple",' in src
+
+
+def test_search_uses_plainto_tsquery_with_explicit_regconfig():
+    """search.py must call plainto_tsquery with explicit regconfig (IMMUTABLE form)."""
+    src = SEARCH_ROUTER.read_text()
+    assert "plainto_tsquery('simple'," in src or 'plainto_tsquery("simple",' in src
+
+
+def test_fts_expression_present_in_search_router():
+    """AST check: search.py contains a string literal with to_tsvector and @@."""
+    tree = ast.parse(SEARCH_ROUTER.read_text())
+    found_fts = False
+    for node in ast.walk(tree):
+        if isinstance(node, ast.Constant) and isinstance(node.value, str):
+            if "to_tsvector" in node.value and "@@" in node.value:
+                found_fts = True
+                break
+    assert found_fts, (
+        "search.py no longer contains a to_tsvector + @@ FTS condition. "
+        "If GET /api/search was removed, delete this file (T-003a complete via T-035/T-037)."
+    )
