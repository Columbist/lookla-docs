index 7824213..cd01ea4 100644
--- a/frontend/lib/api.ts
+++ b/frontend/lib/api.ts
@@ -39,6 +39,27 @@ export const api = {
   categories: (lang = 'el') => apiFetch<Category[]>(`/categories?lang=${lang}`),
 };
 
+// GET /api/areas for the homepage AreaGrid (T-008) — SSR-only, revalidated
+// every 24h. Deliberately bypasses apiFetch(): Next.js rejects combining
+// `cache: 'no-store'` (apiFetch's default) with `next.revalidate`, and this
+// call needs neither apiFetch's browser-credential forwarding (server-only,
+// public/unauthenticated data) nor its no-store default. Throws on any
+// failure or malformed payload — callers decide the fallback (see
+// HomePage in app/[locale]/page.tsx), this function never returns partial
+// or fabricated data.
+export async function getHomepageAreas(): Promise<AreaItem[]> {
+  const res = await fetch(`${API_BASE}/areas?region=attica`, {
+    next: { revalidate: 86400 },
+    headers: { 'Content-Type': 'application/json' },
+  });
+  if (!res.ok) throw new Error(`API ${res.status}: /areas`);
+  const data = await res.json();
+  if (!data || !Array.isArray(data.items)) {
+    throw new Error('malformed /api/areas response');
+  }
+  return data.items as AreaItem[];
+}
+
 // Types
 export interface SalonListItem {
   id: number; name: string; slug?: string;
