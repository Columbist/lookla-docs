+import { test, describe } from 'node:test';
+import assert from 'node:assert/strict';
+import { selectPopularAreas, resolveHomepageAreas, FALLBACK_AREAS } from './areaGrid';
+import { getAreaName } from './areaFilter';
+import type { AreaItem } from './api';
+
+function area(overrides: Partial<AreaItem>): AreaItem {
+  return {
+    slug: 'test-area', name_el: 'Τεστ', name_en: 'Test', name_ru: 'Тест', name_uk: 'Тест',
+    salon_count: 10, region: 'attica', city: 'athens',
+    ...overrides,
+  };
+}
+
+describe('selectPopularAreas', () => {
+  test('drops zero and negative salon_count entries', () => {
+    const items = [
+      area({ slug: 'a', salon_count: 5 }),
+      area({ slug: 'b', salon_count: 0 }),
+      area({ slug: 'c', salon_count: -1 }),
+    ];
+    const result = selectPopularAreas(items);
+    assert.deepEqual(result.map(a => a.slug), ['a']);
+  });
+
+  test('sorts by salon_count descending', () => {
+    const items = [
+      area({ slug: 'low', salon_count: 5 }),
+      area({ slug: 'high', salon_count: 100 }),
+      area({ slug: 'mid', salon_count: 50 }),
+    ];
+    const result = selectPopularAreas(items);
+    assert.deepEqual(result.map(a => a.slug), ['high', 'mid', 'low']);
+  });
+
+  test('uses slug as a deterministic tie-breaker for equal salon_count', () => {
+    const items = [
+      area({ slug: 'zebra', salon_count: 10 }),
+      area({ slug: 'alpha', salon_count: 10 }),
+      area({ slug: 'mike', salon_count: 10 }),
+    ];
+    const result = selectPopularAreas(items);
+    assert.deepEqual(result.map(a => a.slug), ['alpha', 'mike', 'zebra']);
+  });
+
+  test('displays at most 8 areas', () => {
+    const items = Array.from({ length: 15 }, (_, i) => area({ slug: `area-${i}`, salon_count: i + 1 }));
+    const result = selectPopularAreas(items);
+    assert.equal(result.length, 8);
+  });
+
+  test('at least 6 areas appear with a normal API response', () => {
+    const items = Array.from({ length: 10 }, (_, i) => area({ slug: `area-${i}`, salon_count: (i + 1) * 3 }));
+    const result = selectPopularAreas(items);
+    assert.ok(result.length >= 6, `expected >= 6, got ${result.length}`);
+  });
+
+  test('does not mutate the input array', () => {
+    const items = [area({ slug: 'b', salon_count: 1 }), area({ slug: 'a', salon_count: 2 })];
+    const snapshot = items.map(a => a.slug);
+    selectPopularAreas(items);
+    assert.deepEqual(items.map(a => a.slug), snapshot);
+  });
+});
+
+describe('resolveHomepageAreas (fallback activation)', () => {
+  test('activates fallback when items is null (API/HTTP failure)', () => {
+    const result = resolveHomepageAreas(null);
+    assert.deepEqual(result, FALLBACK_AREAS);
+  });
+
+  test('activates fallback when items is an empty array', () => {
+    const result = resolveHomepageAreas([]);
+    assert.deepEqual(result, FALLBACK_AREAS);
+  });
+
+  test('activates fallback when every item has salon_count <= 0', () => {
+    const result = resolveHomepageAreas([area({ salon_count: 0 }), area({ slug: 'b', salon_count: -3 })]);
+    assert.deepEqual(result, FALLBACK_AREAS);
+  });
+
+  test('uses real selection when a normal response is available', () => {
+    const items = [area({ slug: 'real-area', salon_count: 42 })];
+    const result = resolveHomepageAreas(items);
+    assert.deepEqual(result.map(a => a.slug), ['real-area']);
+  });
+});
+
+describe('FALLBACK_AREAS', () => {
+  const expectedSlugs = [
+    'glyfada', 'athens-center', 'piraeus', 'marousi',
+    'kallithea', 'nea-smyrni', 'chalandri', 'kifissia',
+  ];
+
+  test('contains exactly the expected stable slugs', () => {
+    assert.deepEqual(FALLBACK_AREAS.map(a => a.slug), expectedSlugs);
+  });
+
+  test('does not show fake salon counts', () => {
+    for (const a of FALLBACK_AREAS) {
+      assert.equal(a.salon_count, 0, `${a.slug} must have salon_count 0, not an invented number`);
+    }
+  });
+
+  test('has all four localized names for every entry', () => {
+    for (const a of FALLBACK_AREAS) {
+      for (const field of ['name_el', 'name_en', 'name_ru', 'name_uk'] as const) {
+        assert.ok(a[field] && a[field].length > 0, `${a.slug}.${field} must be a non-empty localized name`);
+      }
+    }
+  });
+
+  test('area names resolve correctly per locale via the shared T-007 helper', () => {
+    const glyfada = FALLBACK_AREAS.find(a => a.slug === 'glyfada')!;
+    assert.equal(getAreaName(glyfada, 'el'), 'Γλυφάδα');
+    assert.equal(getAreaName(glyfada, 'en'), 'Glyfada');
+    assert.equal(getAreaName(glyfada, 'ru'), 'Глифада');
+    assert.equal(getAreaName(glyfada, 'uk'), 'Гліфада');
+  });
+});
+
+describe('homepage message files', () => {
+  test('all four locales define home.popular_areas', async () => {
+    const fs = await import('node:fs');
+    const path = await import('node:path');
+    const { fileURLToPath } = await import('node:url');
+    const here = path.dirname(fileURLToPath(import.meta.url));
+    const dir = path.join(here, '..', 'messages');
+    for (const locale of ['el', 'en', 'ru', 'uk']) {
+      const messages = JSON.parse(fs.readFileSync(path.join(dir, `${locale}.json`), 'utf-8'));
+      const heading = messages?.home?.popular_areas;
+      assert.ok(typeof heading === 'string' && heading.length > 0, `${locale}.json home.popular_areas missing or empty`);
+    }
+  });
+});
