@@ -0,0 +1,68 @@
+import { test, describe, beforeEach, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+import { getHomepageAreas } from './api';
+
+describe('getHomepageAreas', () => {
+  let originalFetch: typeof globalThis.fetch;
+
+  beforeEach(() => {
+    originalFetch = globalThis.fetch;
+  });
+
+  afterEach(() => {
+    globalThis.fetch = originalFetch;
+  });
+
+  test('reads areas from a valid response items array', async () => {
+    globalThis.fetch = (async () => ({
+      ok: true,
+      json: async () => ({
+        items: [{ slug: 'glyfada', name_el: 'Γλυφάδα', name_en: 'Glyfada', name_ru: 'Глифада', name_uk: 'Гліфада', salon_count: 76, region: 'attica', city: 'athens' }],
+      }),
+    })) as unknown as typeof fetch;
+
+    const result = await getHomepageAreas();
+    assert.equal(result.length, 1);
+    assert.equal(result[0].slug, 'glyfada');
+  });
+
+  test('throws on HTTP failure — caller catches this into the fallback path', async () => {
+    globalThis.fetch = (async () => ({ ok: false, status: 502, json: async () => ({}) })) as unknown as typeof fetch;
+    await assert.rejects(() => getHomepageAreas());
+  });
+
+  test('throws on a malformed payload (items is not an array)', async () => {
+    globalThis.fetch = (async () => ({ ok: true, json: async () => ({ notItems: [] }) })) as unknown as typeof fetch;
+    await assert.rejects(() => getHomepageAreas());
+  });
+
+  test('throws when items is present but not an array', async () => {
+    globalThis.fetch = (async () => ({ ok: true, json: async () => ({ items: 'not-an-array' }) })) as unknown as typeof fetch;
+    await assert.rejects(() => getHomepageAreas());
+  });
+
+  test('requests with next.revalidate 86400 (24h SSR cache)', async () => {
+    let capturedInit: RequestInit | undefined;
+    globalThis.fetch = (async (_url, init) => {
+      capturedInit = init as RequestInit;
+      return { ok: true, json: async () => ({ items: [] }) } as Response;
+    }) as unknown as typeof fetch;
+
+    await getHomepageAreas();
+    assert.equal((capturedInit as any)?.next?.revalidate, 86400);
+  });
+
+  test('requests region=attica and does not forward credentials', async () => {
+    let capturedUrl = '';
+    let capturedInit: RequestInit | undefined;
+    globalThis.fetch = (async (url, init) => {
+      capturedUrl = String(url);
+      capturedInit = init as RequestInit;
+      return { ok: true, json: async () => ({ items: [] }) } as Response;
+    }) as unknown as typeof fetch;
+
+    await getHomepageAreas();
+    assert.ok(capturedUrl.includes('/areas?region=attica'), capturedUrl);
+    assert.equal(capturedInit?.credentials, undefined);
+  });
+});
