+// Pure helpers for the homepage AreaGrid (T-008). Dependency-free (no
+// React/DOM) so they can run under node:test without a browser/JSDOM —
+// same convention as lib/areaFilter.ts (T-007).
+import type { AreaItem } from '@/lib/api';
+
+const DISPLAY_LIMIT = 8;
+
+/**
+ * Selects the popular areas to show on the homepage from a raw
+ * GET /api/areas response: drops zero/negative-count entries, sorts by
+ * salon_count descending with the stable slug as a deterministic
+ * tie-breaker, and caps at DISPLAY_LIMIT. Does not mutate `items` — filter
+ * already returns a new array before sort runs on it.
+ */
+export function selectPopularAreas(items: AreaItem[]): AreaItem[] {
+  return items
+    .filter(area => area.salon_count > 0)
+    .sort((a, b) => b.salon_count - a.salon_count || a.slug.localeCompare(b.slug))
+    .slice(0, DISPLAY_LIMIT);
+}
+
+/**
+ * Homepage AreaGrid data source, combining selection with the static
+ * fallback: `items` is whatever GET /api/areas produced (or null if the
+ * request failed/threw — see getHomepageAreas() in lib/api.ts). Falls back
+ * to FALLBACK_AREAS whenever selection would otherwise be empty — API
+ * failure, malformed payload (both surfaced as null upstream), an empty
+ * items array, or every item having salon_count <= 0.
+ */
+export function resolveHomepageAreas(items: AreaItem[] | null): AreaItem[] {
+  const popular = items ? selectPopularAreas(items) : [];
+  return popular.length > 0 ? popular : FALLBACK_AREAS;
+}
+
+// Static availability fallback for when GET /api/areas fails, times out, or
+// returns an invalid/empty payload. Not the canonical data source — see
+// selectPopularAreas above and getHomepageAreas() in lib/api.ts. Deliberately
+// has no salon_count (0 = "not shown", see AreaGrid.tsx) since a fabricated
+// count would misrepresent live data. Slugs/names must stay in sync with
+// backend/app/data/area_metadata.py — this list intentionally does not
+// import from there since the frontend has no access to the Python module.
+export const FALLBACK_AREAS: AreaItem[] = [
