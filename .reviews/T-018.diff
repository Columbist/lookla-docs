+import { test, describe } from 'node:test';
+import assert from 'node:assert/strict';
+import fs from 'node:fs';
+import path from 'node:path';
+import { fileURLToPath } from 'node:url';
+
+const here = path.dirname(fileURLToPath(import.meta.url));
+const frontendRoot = path.join(here, '..');
+
+function read(relPath: string): string {
+  return fs.readFileSync(path.join(frontendRoot, relPath), 'utf-8');
+}
+
+describe('T-018: CookieConsent.tsx — banner gating and behaviour (source-pattern verification; live behaviour re-verified via Playwright in isolated runtime, per T-010 precedent for this codebase\'s test infra)', () => {
+  const source = read('components/CookieConsent.tsx');
+
+  test('is a client component', () => {
+    assert.ok(source.startsWith("'use client';"));
+  });
+
+  test('feature disabled -> no banner: gates on isAnalyticsConsentFeatureEnabled() before ever setting a visible mode', () => {
+    assert.ok(/if \(!isAnalyticsConsentFeatureEnabled\(\)\) return;/.test(source));
+  });
+
+  test('first-visit banner only appears when consent is unset — existing granted/rejected choice suppresses it', () => {
+    assert.ok(/if \(current === 'unset'\) setMode\('banner'\)/.test(source), 'banner must only auto-open for the unset case');
+  });
+
+  test('Accept and Reject are both rendered unconditionally together (same layer, not one gated behind the other)', () => {
+    const rejectIdx = source.indexOf("choose(false)");
+    const acceptIdx = source.indexOf("choose(true)");
+    assert.ok(rejectIdx > -1 && acceptIdx > -1, 'both actions must exist');
+    const between = source.slice(rejectIdx, acceptIdx);
+    assert.ok(!/\{isSettings|\{mode ===/.test(between), 'Accept must not be behind an extra conditional that Reject is not also behind');
+  });
+
+  test('Accept and Reject buttons share an identical className (equal visual weight — no larger/brighter Accept)', () => {
+    const buttonBlocks = [...source.matchAll(/onClick=\{\(\) => choose\((true|false)\)\}[\s\S]{0,200}?className="([^"]+)"/g)];
+    assert.equal(buttonBlocks.length, 2, 'expected exactly one Accept and one Reject button block');
+    const classNames = buttonBlocks.map(m => m[2]);
+    assert.equal(classNames[0], classNames[1], `Accept/Reject className must be identical — got ${JSON.stringify(classNames)}`);
+  });
+
+  test('both actions call setAnalyticsConsent then close() — a single action closes the banner, no separate "continue without choosing" path', () => {
+    assert.ok(/const choose = useCallback\(\(granted: boolean\) => \{\s*setAnalyticsConsent\(granted\);[\s\S]*?close\(\);/.test(source));
+  });
+
+  test('does not use the text "Accept to continue" or any cookie-wall phrasing', () => {
+    assert.ok(!/accept to continue/i.test(source));
+  });
+
+  test('initial mode is "hidden", not pre-granted — no preselected consent', () => {
+    assert.ok(/useState<Mode>\('hidden'\)/.test(source));
+  });
+
+  test('Escape only closes the reopened settings view, not the initial unanswered banner', () => {
+    assert.ok(/if \(mode !== 'settings'\) return;/.test(source));
+    assert.ok(/e\.key === 'Escape'/.test(source));
+  });
+
+  test('close() returns focus to the stored trigger element (footer button) via optional chaining, not an unguarded call', () => {
+    assert.ok(/triggerRef\.current\?\.focus\(\)/.test(source));
+  });
+
+  test('no focus-trap library or manual trap implementation (avoids risk of an incorrectly-implemented trap)', () => {
+    assert.ok(!/focus-trap|trapFocus|inert=/.test(source));
+  });
+
+  test('no background scroll lock (no overflow:hidden / document.body.style manipulation) — must stay a non-blocking bottom banner', () => {
+    assert.ok(!/overflow.*hidden|document\.body\.style/.test(source));
+  });
+
+  test('does not itself listen for lookla:consent-change to load analytics — that remains T-014 scope', () => {
+    assert.ok(!/addEventListener\(CONSENT_CHANGE_EVENT/.test(source), 'T-018 must not react to its own consent-change event by loading anything');
+  });
+
+  test('no GA4 / GTM reference anywhere in the component', () => {
+    assert.ok(!/googletagmanager|gtag\(|google-analytics/i.test(source));
+  });
+});
+
+describe('T-018: Footer.tsx — cookie-settings control', () => {
+  const source = read('components/Footer.tsx');
+
+  test('is a client component', () => {
+    assert.ok(source.startsWith("'use client';"));
+  });
+
+  test('cookie-settings control is gated on the same feature flag as the banner', () => {
+    assert.ok(/isAnalyticsConsentFeatureEnabled\(\)\s*&&/.test(source));
+  });
+
+  test('cookie-settings control is a real <button type="button">, not an href="#" link', () => {
+    assert.ok(/<button\s+type="button"[\s\S]*?openCookieSettings/.test(source));
+    assert.ok(!/href="#"/.test(source));
+  });
+
+  test('dispatches the shared CONSENT_OPEN_SETTINGS_EVENT constant (not a locally-duplicated string, avoiding drift with CookieConsent.tsx)', () => {
+    assert.ok(source.includes("import { isAnalyticsConsentFeatureEnabled, CONSENT_OPEN_SETTINGS_EVENT } from '@/lib/consent'"));
+    assert.ok(source.includes('new CustomEvent(CONSENT_OPEN_SETTINGS_EVENT'));
+  });
+
+  test('always links to Privacy Policy and Cookie Policy regardless of the analytics feature flag', () => {
+    assert.ok(/href=\{`\$\{prefix\}\/privacy`\}/.test(source));
+    assert.ok(/href=\{`\$\{prefix\}\/cookies`\}/.test(source));
+  });
+
+  test('no GA4 / GTM reference anywhere in the component', () => {
+    assert.ok(!/googletagmanager|gtag\(|google-analytics/i.test(source));
+  });
+});
+
+describe('T-018: no consent-gated content blocking (rejecting analytics must not disable site functionality)', () => {
+  test('no component outside consent.ts/CookieConsent.tsx/Footer.tsx reads analytics consent to gate rendering', () => {
+    const searchDirs = ['app', 'components'];
+    const offenders: string[] = [];
+    function walk(dir: string) {
+      for (const entry of fs.readdirSync(path.join(frontendRoot, dir), { withFileTypes: true })) {
+        const rel = path.join(dir, entry.name);
+        if (entry.isDirectory()) { walk(rel); continue; }
+        if (!/\.(ts|tsx)$/.test(entry.name)) continue;
+        if (rel.includes('CookieConsent.tsx') || rel.includes('Footer.tsx')) continue;
+        if (rel.endsWith('.test.ts')) continue;
+        const content = fs.readFileSync(path.join(frontendRoot, rel), 'utf-8');
+        if (/getAnalyticsConsent|isAnalyticsConsentFeatureEnabled/.test(content)) offenders.push(rel);
+      }
+    }
+    for (const d of searchDirs) walk(d);
+    assert.deepEqual(offenders, [], `only CookieConsent.tsx/Footer.tsx may reference the consent gate — found it also in: ${offenders.join(', ')}`);
+  });
+
+  test('no NEXT_PUBLIC_ANALYTICS_CONSENT_ENABLED=true is set anywhere in tracked env/config files in this repo', () => {
+    const candidates = ['.env.example', 'next.config.mjs'];
+    for (const c of candidates) {
+      const full = path.join(frontendRoot, c);
+      if (!fs.existsSync(full)) continue;
+      const content = fs.readFileSync(full, 'utf-8');
+      assert.ok(!/NEXT_PUBLIC_ANALYTICS_CONSENT_ENABLED\s*=\s*true/.test(content), `${c} must not enable the flag — T-018 ships it dormant, T-014 turns it on`);
+    }
+  });
+});
