@@ -0,0 +1,132 @@
+import { test, describe } from 'node:test';
+import assert from 'node:assert/strict';
+import fs from 'node:fs';
+import path from 'node:path';
+import { fileURLToPath } from 'node:url';
+import { COOKIE_POLICY_CONTENT } from '../app/[locale]/cookies/content';
+import { PRIVACY_CONTENT } from '../app/[locale]/privacy/content';
+
+const here = path.dirname(fileURLToPath(import.meta.url));
+const frontendRoot = path.join(here, '..');
+const LOCALES = ['el', 'en', 'ru', 'uk'] as const;
+
+describe('T-018: Cookie Policy page exists and is SSR', () => {
+  test('page.tsx exists at app/[locale]/cookies/page.tsx', () => {
+    assert.ok(fs.existsSync(path.join(frontendRoot, 'app', '[locale]', 'cookies', 'page.tsx')));
+  });
+
+  test('page.tsx has no "use client" directive — server component (SSR)', () => {
+    const source = fs.readFileSync(path.join(frontendRoot, 'app', '[locale]', 'cookies', 'page.tsx'), 'utf-8');
+    assert.ok(!source.includes("'use client'"));
+  });
+
+  test('page.tsx exports a default async CookiePolicyPage component', () => {
+    const source = fs.readFileSync(path.join(frontendRoot, 'app', '[locale]', 'cookies', 'page.tsx'), 'utf-8');
+    assert.ok(source.includes('export default async function CookiePolicyPage'));
+  });
+});
+
+describe('T-018: Cookie Policy content covers all 4 locales with matching structure', () => {
+  for (const locale of LOCALES) {
+    test(`${locale} content exists and is non-empty`, () => {
+      const c = COOKIE_POLICY_CONTENT[locale];
+      assert.ok(c.title.length > 0);
+      assert.ok(c.lastUpdated.length > 0);
+      assert.ok(c.intro.length > 0);
+      assert.ok(c.sections.length > 0);
+    });
+
+    test(`${locale} section headings are sequential (1., 2., 3., ...)`, () => {
+      const c = COOKIE_POLICY_CONTENT[locale];
+      const numbers = c.sections.map(s => Number(s.heading.match(/^(\d+)\./)![1]));
+      assert.deepEqual(numbers, Array.from({ length: c.sections.length }, (_, i) => i + 1));
+    });
+  }
+
+  test('all 4 locales have the same number of sections', () => {
+    const counts = LOCALES.map(l => COOKIE_POLICY_CONTENT[l].sections.length);
+    assert.ok(counts.every(c => c === counts[0]), JSON.stringify(counts));
+  });
+});
+
+describe('T-018: controller identity and contact match the Privacy Policy', () => {
+  test('English Cookie Policy names the same controller as the Privacy Policy', () => {
+    const cookieText = JSON.stringify(COOKIE_POLICY_CONTENT.en);
+    const privacyText = JSON.stringify(PRIVACY_CONTENT.en.intro);
+    assert.ok(cookieText.includes('Zhuykov Andrey'));
+    assert.ok(privacyText.includes('Zhuykov Andrey'));
+  });
+
+  for (const locale of LOCALES) {
+    test(`${locale} references hello@lookla.gr`, () => {
+      assert.ok(JSON.stringify(COOKIE_POLICY_CONTENT[locale]).includes('hello@lookla.gr'));
+    });
+  }
+});
+
+describe('T-018: every verified cookie appears exactly once in the table, no speculative cookies', () => {
+  const expectedCookies = ['access_token', 'refresh_token', 'oauth_csrf', 'NEXT_LOCALE', 'lookla_consent'];
+
+  test('English content lists each verified cookie exactly once', () => {
+    const text = JSON.stringify(COOKIE_POLICY_CONTENT.en.sections);
+    for (const name of expectedCookies) {
+      const occurrences = (text.match(new RegExp(`• ${name} —`, 'g')) || []).length;
+      assert.equal(occurrences, 1, `${name} should appear exactly once as a table row, found ${occurrences}`);
+    }
+  });
+
+  test('does not list any _ga cookie as currently active', () => {
+    const text = JSON.stringify(COOKIE_POLICY_CONTENT.en.sections);
+    assert.ok(!/_ga[,\s]/i.test(text) && !/•\s*_ga/i.test(text), 'must not present a speculative _ga cookie as currently installed');
+  });
+
+  test('GA4 is explicitly described as inactive, not merely absent from the list', () => {
+    const text = JSON.stringify(COOKIE_POLICY_CONTENT.en.sections);
+    assert.ok(/does not use Google Analytics \(GA4\)/i.test(text));
+  });
+
+  test('states analytics will only run after active acceptance, never by default', () => {
+    const text = JSON.stringify(COOKIE_POLICY_CONTENT.en.sections);
+    assert.ok(/never by default/i.test(text));
+  });
+});
+
+describe('T-018: Cloudflare cookie claims are honestly qualified (verified-absent, not claimed-never)', () => {
+  test('states Cloudflare set no cookie during the actual test performed', () => {
+    const text = JSON.stringify(COOKIE_POLICY_CONTENT.en.sections);
+    assert.ok(/did not set any cookie/i.test(text));
+  });
+
+  test('does not claim Cloudflare never sets a cookie under any condition', () => {
+    const text = JSON.stringify(COOKIE_POLICY_CONTENT.en.sections);
+    assert.ok(/We are not claiming Cloudflare never sets a cookie/i.test(text));
+  });
+
+  test('does not classify Cloudflare security/challenge cookies as analytics', () => {
+    // Check only the Cloudflare section's own paragraphs, not the whole flattened
+    // sections array — "analytics" legitimately appears in the very next section
+    // (6. Optional analytics), which a substring-spanning regex would false-positive on.
+    const cloudflareSection = COOKIE_POLICY_CONTENT.en.sections.find(s => s.heading.includes('Cloudflare'));
+    assert.ok(cloudflareSection, 'expected a dedicated Cloudflare section');
+    const text = cloudflareSection!.paragraphs.join(' ');
+    assert.ok(!/analytics/i.test(text), 'the Cloudflare section itself must not describe any Cloudflare cookie as analytics');
+  });
+});
+
+describe('T-018: Privacy Policy and Cookie Policy cross-link correctly', () => {
+  test('Cookie Policy links back to the Privacy Policy', () => {
+    const source = fs.readFileSync(path.join(frontendRoot, 'app', '[locale]', 'cookies', 'page.tsx'), 'utf-8');
+    assert.ok(source.includes('/privacy'));
+  });
+
+  test('Privacy Policy references the Cookie Policy for the full cookie list (not "planned")', () => {
+    const text = JSON.stringify(PRIVACY_CONTENT.en.sections);
+    assert.ok(/Cookie Policy/i.test(text));
+    assert.ok(!/planned as separate, upcoming work/i.test(text), 'Privacy Policy must no longer describe the Cookie Policy as merely planned — it now exists');
+  });
+
+  test('Privacy Policy describes the lookla_consent cookie now that it exists', () => {
+    const text = JSON.stringify(PRIVACY_CONTENT.en.sections);
+    assert.ok(text.includes('lookla_consent'));
+  });
+});
