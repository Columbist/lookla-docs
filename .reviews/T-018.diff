+'use client';
+import Link from 'next/link';
+import { useTranslations, useLocale } from 'next-intl';
+import { isAnalyticsConsentFeatureEnabled, CONSENT_OPEN_SETTINGS_EVENT } from '@/lib/consent';
+import LanguageSwitcher from '@/components/LanguageSwitcher';
+
+export default function Footer() {
+  const t = useTranslations('footer');
+  const locale = useLocale();
+  const prefix = locale === 'el' ? '' : `/${locale}`;
+
+  function openCookieSettings(e: React.MouseEvent<HTMLButtonElement>) {
+    window.dispatchEvent(new CustomEvent(CONSENT_OPEN_SETTINGS_EVENT, { detail: { trigger: e.currentTarget } }));
+  }
+
+  return (
+    <footer className="border-t border-gray-100 bg-white py-6 px-4">
+      <div className="max-w-4xl mx-auto flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm text-gray-500">
+        <Link href={`${prefix}/privacy`} className="hover:text-gray-700">{t('privacy')}</Link>
+        <Link href={`${prefix}/cookies`} className="hover:text-gray-700">{t('cookies')}</Link>
+        {isAnalyticsConsentFeatureEnabled() && (
+          <button
+            type="button"
+            onClick={openCookieSettings}
+            className="hover:text-gray-700 underline-offset-2 hover:underline"
+          >
+            {t('cookieSettings')}
+          </button>
+        )}
+      </div>
+      <div className="max-w-6xl mx-auto px-4 pt-4 text-center text-sm text-gray-400">
+        © 2026 Lookla — Beauty Marketplace Greece
+        <LanguageSwitcher currentLocale={locale} />
+      </div>
+    </footer>
+  );
+}
