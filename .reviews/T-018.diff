diff --git a/frontend/components/CookieConsent.tsx b/frontend/components/CookieConsent.tsx
new file mode 100644
index 0000000..5dbee64
--- /dev/null
+++ b/frontend/components/CookieConsent.tsx
@@ -0,0 +1,105 @@
+'use client';
+import { useCallback, useEffect, useRef, useState } from 'react';
+import Link from 'next/link';
+import { useTranslations, useLocale } from 'next-intl';
+import {
+  getAnalyticsConsent,
+  setAnalyticsConsent,
+  isAnalyticsConsentFeatureEnabled,
+  CONSENT_OPEN_SETTINGS_EVENT,
+  type ConsentValue,
+} from '@/lib/consent';
+
+type Mode = 'hidden' | 'banner' | 'settings';
+
+export default function CookieConsent() {
+  const t = useTranslations('cookieConsent');
+  const locale = useLocale();
+  const prefix = locale === 'el' ? '' : `/${locale}`;
+  const [mode, setMode] = useState<Mode>('hidden');
+  const [, setConsent] = useState<ConsentValue>('unset');
+  const triggerRef = useRef<HTMLElement | null>(null);
+
+  useEffect(() => {
+    if (!isAnalyticsConsentFeatureEnabled()) return;
+
+    const current = getAnalyticsConsent();
+    setConsent(current);
+    if (current === 'unset') setMode('banner');
+
+    function handleOpenSettings(e: Event) {
+      const detail = (e as CustomEvent<{ trigger?: HTMLElement }>).detail;
+      triggerRef.current = detail?.trigger ?? null;
+      setConsent(getAnalyticsConsent());
+      setMode('settings');
+    }
+    window.addEventListener(CONSENT_OPEN_SETTINGS_EVENT, handleOpenSettings);
+    return () => window.removeEventListener(CONSENT_OPEN_SETTINGS_EVENT, handleOpenSettings);
+  }, []);
+
+  const close = useCallback(() => {
+    setMode('hidden');
+    triggerRef.current?.focus();
+  }, []);
+
+  const choose = useCallback((granted: boolean) => {
+    setAnalyticsConsent(granted);
+    setConsent(granted ? 'granted' : 'rejected');
+    close();
+  }, [close]);
+
+  // Escape closes only the reopened settings view — the initial unanswered banner has no dismiss-without-choosing path.
+  useEffect(() => {
+    if (mode !== 'settings') return;
+    function handleKey(e: KeyboardEvent) {
+      if (e.key === 'Escape') close();
+    }
+    window.addEventListener('keydown', handleKey);
+    return () => window.removeEventListener('keydown', handleKey);
+  }, [mode, close]);
+
+  if (mode === 'hidden') return null;
+
+  const isSettings = mode === 'settings';
+
+  return (
+    <div
+      role={isSettings ? 'dialog' : 'region'}
+      aria-label={isSettings ? t('settingsAriaLabel') : t('bannerAriaLabel')}
+      className="fixed bottom-0 inset-x-0 z-50 bg-white border-t border-gray-200 shadow-lg px-4 py-4"
+    >
+      <div className="max-w-3xl mx-auto flex flex-col sm:flex-row sm:items-center gap-3">
+        <p className="text-sm text-gray-700 flex-1">
+          {t('message')}{' '}
+          <Link href={`${prefix}/cookies`} className="underline text-pink-600">{t('policyLink')}</Link>
+        </p>
+        <div className="flex gap-2 shrink-0">
+          <button
+            type="button"
+            onClick={() => choose(false)}
+            className="px-4 py-2 rounded-lg text-sm font-medium border border-gray-300 text-gray-700 hover:bg-gray-50"
+          >
+            {t('reject')}
+          </button>
+          <button
+            type="button"
+            onClick={() => choose(true)}
+            className="px-4 py-2 rounded-lg text-sm font-medium border border-gray-300 text-gray-700 hover:bg-gray-50"
+          >
+            {t('accept')}
+          </button>
+          {isSettings && (
+            <button
+              type="button"
+              onClick={close}
+              aria-label={t('close')}
+              className="px-2 text-gray-400 hover:text-gray-600 text-lg"
+            >
+              ×
+            </button>
+          )}
+        </div>
+      </div>
+    </div>
+  );
+}
