@@ -0,0 +1,60 @@
+/**
+ * T-018: canonical analytics-consent contract. Dependency-free by design —
+ * this is a single boolean-shaped preference, not a multi-category CMP.
+ */
+
+export const CONSENT_COOKIE_NAME = 'lookla_consent';
+export const CONSENT_COOKIE_MAX_AGE_SECONDS = 60 * 60 * 24 * 180; // 180 days
+export const CONSENT_CHANGE_EVENT = 'lookla:consent-change';
+/** Dispatched by the footer's "Cookie settings" control; CookieConsent listens for this to reopen. */
+export const CONSENT_OPEN_SETTINGS_EVENT = 'lookla:open-cookie-settings';
+
+/** Reads the analytics-consent feature gate. Unset/not "true" means the banner and settings control stay dormant — T-014 turns this on once GA4 is actually configured. */
+export function isAnalyticsConsentFeatureEnabled(): boolean {
+  return process.env.NEXT_PUBLIC_ANALYTICS_CONSENT_ENABLED === 'true';
+}
+
+export type ConsentValue = 'granted' | 'rejected' | 'unset';
+
+export interface ConsentChangeEventDetail {
+  analytics: boolean;
+}
+
+/** Reads the raw `lookla_consent` cookie value out of a `document.cookie`-shaped string. */
+export function parseConsentCookie(cookieString: string | undefined | null): ConsentValue {
+  if (!cookieString) return 'unset';
+  const match = cookieString.split(';').map(s => s.trim()).find(s => s.startsWith(`${CONSENT_COOKIE_NAME}=`));
+  if (!match) return 'unset';
+  const raw = match.slice(CONSENT_COOKIE_NAME.length + 1);
+  if (raw === '1') return 'granted';
+  if (raw === '0') return 'rejected';
+  return 'unset';
+}
+
+/** Reads consent from the live browser `document.cookie`. No-op (returns 'unset') outside the browser. */
+export function getAnalyticsConsent(): ConsentValue {
+  if (typeof document === 'undefined') return 'unset';
+  return parseConsentCookie(document.cookie);
+}
+
+/**
+ * Writes the consent cookie and dispatches `lookla:consent-change`.
+ * Not HttpOnly — the banner, the settings control, and T-014's future GA4
+ * loader all need to read this cookie from client-side JS.
+ */
+export function setAnalyticsConsent(granted: boolean): void {
+  if (typeof document === 'undefined') return;
+  const value = granted ? '1' : '0';
+  const isSecureContext = typeof window !== 'undefined' && window.location.protocol === 'https:';
+  const attrs = [
+    `${CONSENT_COOKIE_NAME}=${value}`,
+    'Path=/',
+    `Max-Age=${CONSENT_COOKIE_MAX_AGE_SECONDS}`,
+    'SameSite=Lax',
+  ];
+  if (isSecureContext) attrs.push('Secure');
+  document.cookie = attrs.join('; ');
+
+  const detail: ConsentChangeEventDetail = { analytics: granted };
+  window.dispatchEvent(new CustomEvent<ConsentChangeEventDetail>(CONSENT_CHANGE_EVENT, { detail }));
+}
