@@ -0,0 +1,88 @@
+import { test, describe } from 'node:test';
+import assert from 'node:assert/strict';
+import {
+  parseConsentCookie,
+  CONSENT_COOKIE_NAME,
+  CONSENT_COOKIE_MAX_AGE_SECONDS,
+  CONSENT_CHANGE_EVENT,
+} from './consent';
+
+describe('T-018: parseConsentCookie', () => {
+  test('missing cookie header -> unset', () => {
+    assert.equal(parseConsentCookie(undefined), 'unset');
+    assert.equal(parseConsentCookie(null), 'unset');
+    assert.equal(parseConsentCookie(''), 'unset');
+  });
+
+  test('lookla_consent=1 -> granted', () => {
+    assert.equal(parseConsentCookie('lookla_consent=1'), 'granted');
+    assert.equal(parseConsentCookie('NEXT_LOCALE=en; lookla_consent=1'), 'granted');
+  });
+
+  test('lookla_consent=0 -> rejected', () => {
+    assert.equal(parseConsentCookie('lookla_consent=0'), 'rejected');
+    assert.equal(parseConsentCookie('lookla_consent=0; NEXT_LOCALE=en'), 'rejected');
+  });
+
+  test('invalid/unexpected value -> unset, rejected safely rather than trusted', () => {
+    assert.equal(parseConsentCookie('lookla_consent=yes'), 'unset');
+    assert.equal(parseConsentCookie('lookla_consent=true'), 'unset');
+    assert.equal(parseConsentCookie('lookla_consent='), 'unset');
+    assert.equal(parseConsentCookie('lookla_consent=2'), 'unset');
+  });
+
+  test('cookie name constant is exactly "lookla_consent"', () => {
+    assert.equal(CONSENT_COOKIE_NAME, 'lookla_consent');
+  });
+
+  test('max-age constant is exactly 180 days in seconds', () => {
+    assert.equal(CONSENT_COOKIE_MAX_AGE_SECONDS, 60 * 60 * 24 * 180);
+  });
+
+  test('consent-change event name constant is exported', () => {
+    assert.equal(CONSENT_CHANGE_EVENT, 'lookla:consent-change');
+  });
+});
+
+describe('T-018: setAnalyticsConsent — source inspection (jsdom-style DOM APIs unavailable in node:test)', () => {
+  test('consent.ts source writes Path=/, Max-Age=180-day-seconds, SameSite=Lax, and Secure only in a secure context', async () => {
+    const fs = await import('node:fs');
+    const path = await import('node:path');
+    const { fileURLToPath } = await import('node:url');
+    const here = path.dirname(fileURLToPath(import.meta.url));
+    const source = fs.readFileSync(path.join(here, 'consent.ts'), 'utf-8');
+    assert.ok(source.includes("'Path=/'"));
+    assert.ok(source.includes('CONSENT_COOKIE_MAX_AGE_SECONDS}`'));
+    assert.ok(source.includes("'SameSite=Lax'"));
+    assert.ok(source.includes("attrs.push('Secure')"));
+    assert.ok(source.includes('isSecureContext'), 'Secure must be conditional on protocol, not hardcoded (would break local http:// testing)');
+  });
+
+  test('consent.ts never sets HttpOnly (must be readable by client-side JS per the contract)', async () => {
+    const fs = await import('node:fs');
+    const path = await import('node:path');
+    const { fileURLToPath } = await import('node:url');
+    const here = path.dirname(fileURLToPath(import.meta.url));
+    const source = fs.readFileSync(path.join(here, 'consent.ts'), 'utf-8');
+    assert.ok(!/HttpOnly/i.test(source) || source.includes('Not HttpOnly'), 'consent cookie must not be HttpOnly');
+  });
+
+  test('consent.ts stores only "1"/"0" — no identifier, timestamp, IP, user ID, locale, or fingerprint', async () => {
+    const fs = await import('node:fs');
+    const path = await import('node:path');
+    const { fileURLToPath } = await import('node:url');
+    const here = path.dirname(fileURLToPath(import.meta.url));
+    const source = fs.readFileSync(path.join(here, 'consent.ts'), 'utf-8');
+    assert.ok(!/uuid|randomUUID|Date\.now\(\)|timestamp|fingerprint|userId|user_id/i.test(source), 'consent cookie value must remain a bare "1"/"0", nothing else');
+  });
+
+  test('dispatched event detail shape matches { analytics: boolean }', async () => {
+    const fs = await import('node:fs');
+    const path = await import('node:path');
+    const { fileURLToPath } = await import('node:url');
+    const here = path.dirname(fileURLToPath(import.meta.url));
+    const source = fs.readFileSync(path.join(here, 'consent.ts'), 'utf-8');
+    assert.ok(source.includes('const detail: ConsentChangeEventDetail = { analytics: granted }'));
+    assert.ok(source.includes('CustomEvent<ConsentChangeEventDetail>(CONSENT_CHANGE_EVENT, { detail })'));
+  });
+});
