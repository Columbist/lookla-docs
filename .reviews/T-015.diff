+
+// ---------------------------------------------------------------------------
+// T-015: consent-gated GA4 product events.
+//
+// A closed catalogue by design — trackEvent() only accepts the 5 approved
+// event name/parameter-shape combinations below, enforced both at compile
+// time (function overloads) and at runtime (ANALYTICS_EVENT_NAMES allowlist
+// + per-event parameter schemas + a universal denylist). No free-form event
+// name or parameter object from a component can ever reach gtag().
+//
+// None of these events carry PII: no name, email, phone, message text, free-
+// text search query, exact GPS, or destination URL. Every parameter is
+// either a stable non-personal ID (salon_id — the numeric DB primary key,
+// never salon.slug, which typically embeds the business name), a canonical
+// slug (area), or a closed low-cardinality enum.
+// ---------------------------------------------------------------------------
+
+const LOCALE_VALUES: readonly Locale[] = ['el', 'en', 'ru', 'uk'];
+function isLocale(v: string): v is Locale {
+  return (LOCALE_VALUES as readonly string[]).includes(v);
+}
+
+function isOneOf<T extends string>(allowed: readonly T[]): (v: string) => v is T {
+  return (v: string): v is T => (allowed as readonly string[]).includes(v);
+}
+
+/**
+ * Internal salon primary-key IDs only — never a slug. Real slugs observed in
+ * production embed the salon's business name (e.g.
+ * "harris-anagnostopoulos-12608"), which would make salon_id personally
+ * identifying; the numeric id field never does. Bounded to a realistic
+ * primary-key length as a sanity check, not as a cryptographic guarantee.
+ */
+const NUMERIC_ID_RE = /^\d{1,12}$/;
+function isNumericId(v: string): boolean {
+  return NUMERIC_ID_RE.test(v);
+}
+
+/** Canonical area slugs only (e.g. "athens-center") — never arbitrary URL/user text. */
+const AREA_SLUG_RE = /^[a-z0-9-]{1,64}$/;
+function isAreaSlug(v: string): boolean {
+  return AREA_SLUG_RE.test(v);
+}
+
+const RESULT_COUNT_BUCKETS = ['0', '1_5', '6_20', '21_50', '51_plus'] as const;
+export type ResultCountBucket = (typeof RESULT_COUNT_BUCKETS)[number];
+
+/** Buckets a raw result count for search_results_view — the exact count is never transmitted. */
+export function bucketResultCount(count: number): ResultCountBucket {
+  if (count <= 0) return '0';
+  if (count <= 5) return '1_5';
+  if (count <= 20) return '6_20';
+  if (count <= 50) return '21_50';
+  return '51_plus';
+}
+
+/** Stable normalized state key for search_results_view dedup — see buildSearchResultsViewKey below. */
+export function buildSearchResultsViewKey(area: string, bucket: ResultCountBucket, view: 'list' | 'map', locale: Locale): string {
+  return `${area}|${bucket}|${view}|${locale}`;
+}
+
+export const ANALYTICS_EVENT_NAMES = [
+  'salon_open',
+  'contact_action',
+  'search_results_view',
+  'area_select',
+  'language_change',
+] as const;
+export type AnalyticsEventName = (typeof ANALYTICS_EVENT_NAMES)[number];
+
+export interface SalonOpenParams {
+  salon_id: string;
+  source: 'search_list' | 'search_map' | 'homepage' | 'masters';
+  locale: Locale;
+}
+export interface ContactActionParams {
+  salon_id: string;
+  channel: 'phone' | 'whatsapp' | 'website';
+  page: 'salon_detail';
+  locale: Locale;
+}
+export interface SearchResultsViewParams {
+  area: string;
+  result_count_bucket: ResultCountBucket;
+  view: 'list' | 'map';
+  locale: Locale;
+}
+export interface AreaSelectParams {
+  area: string;
+  source: 'homepage_grid' | 'search_filter';
+  locale: Locale;
+}
+export interface LanguageChangeParams {
+  from_locale: Locale;
+  to_locale: Locale;
+  surface: 'header' | 'footer';
+}
+
+/**
+ * Explicit key-name backstop, in addition to the per-event schemas below.
+ * The schemas already only ever copy their own named keys out of a caller's
+ * object — anything else is structurally ignored — so this list is
+ * defense-in-depth for the case a future schema edit accidentally
+ * introduces one of these names: if present anywhere in the raw input
+ * object, the entire event is dropped rather than silently stripped.
+ */
+const DENIED_PARAM_KEYS = new Set([
+  'email', 'phone', 'phone_number', 'whatsapp', 'whatsapp_number', 'viber', 'viber_number',
+  'name', 'user_name', 'salon_name', 'address', 'street', 'message', 'text', 'notes',
+  'description', 'report_description', 'review_text', 'service_name', 'google_account_id',
+  'token', 'access_token', 'refresh_token', 'auth_token', 'verification_token',
+  'lat', 'lng', 'latitude', 'longitude', 'bounds', 'viewport', 'query', 'q', 'search_query',
+  'url', 'destination_url', 'website_url', 'page_location', 'cookie', 'user_id', 'id',
+]);
+
+const MAX_PARAM_LENGTH = 64;
+
+/**
+ * Universal denylist applied to every parameter value regardless of key —
+ * on top of, not instead of, the per-event schema checks below. No space,
+ * no '@', no URL scheme, bounded length: every legitimate value in the
+ * approved catalogue is a short enum token, a hyphenated slug, or a digit
+ * string, and none of them ever look like this — but a name, address,
+ * message, email, or destination URL would.
+ */
+function isSafeGenericValue(v: string): boolean {
+  if (typeof v !== 'string') return false;
+  if (v.length === 0 || v.length > MAX_PARAM_LENGTH) return false;
+  if (/\s/.test(v)) return false;
+  if (v.includes('@')) return false;
+  if (/^[a-z][a-z0-9+.-]*:/i.test(v)) return false; // blocks tel:, mailto:, https://, wa.me-style, etc.
+  return true;
+}
+
+const EVENT_SCHEMAS: Record<AnalyticsEventName, Record<string, (v: string) => boolean>> = {
+  salon_open: {
+    salon_id: isNumericId,
+    source: isOneOf(['search_list', 'search_map', 'homepage', 'masters']),
+    locale: isLocale,
+  },
+  contact_action: {
+    salon_id: isNumericId,
+    channel: isOneOf(['phone', 'whatsapp', 'website']),
+    page: isOneOf(['salon_detail']),
+    locale: isLocale,
+  },
+  search_results_view: {
+    area: (v: string) => v === 'all' || isAreaSlug(v),
+    result_count_bucket: isOneOf(RESULT_COUNT_BUCKETS),
+    view: isOneOf(['list', 'map']),
+    locale: isLocale,
+  },
+  area_select: {
+    area: isAreaSlug,
+    source: isOneOf(['homepage_grid', 'search_filter']),
+    locale: isLocale,
+  },
+  language_change: {
+    from_locale: isLocale,
+    to_locale: isLocale,
+    surface: isOneOf(['header', 'footer']),
+  },
+};
+
+/**
+ * The single entry point for all T-015 product events.
+ *
+ * - No-ops (silently, never throws) unless GA is already initialized
+ *   (window.gtag exists) AND current consent is 'granted' — read live from
+ *   the cookie on every call, never cached, so a mid-session withdrawal
+ *   takes effect on the very next call with no extra wiring.
+ * - Never calls initGtagIfNeeded() itself — T-015 rides on T-014's already-
+ *   consented transport, it does not decide when GA gets initialized.
+ * - Never queues a dropped call for later replay — a call made while
+ *   consent is absent/rejected/withdrawn is simply gone, not deferred.
+ * - Only the 5 approved event names are callable at all (enforced by the
+ *   overloads below); for each, only its own named parameters — after
+ *   passing both the per-event schema and the universal denylist above —
+ *   ever reach gtag().
+ */
+export function trackEvent(name: 'salon_open', parameters: SalonOpenParams): void;
+export function trackEvent(name: 'contact_action', parameters: ContactActionParams): void;
+export function trackEvent(name: 'search_results_view', parameters: SearchResultsViewParams): void;
+export function trackEvent(name: 'area_select', parameters: AreaSelectParams): void;
+export function trackEvent(name: 'language_change', parameters: LanguageChangeParams): void;
+export function trackEvent(
+  name: AnalyticsEventName,
+  parameters: SalonOpenParams | ContactActionParams | SearchResultsViewParams | AreaSelectParams | LanguageChangeParams,
+): void {
+  try {
+    if (!(ANALYTICS_EVENT_NAMES as readonly string[]).includes(name)) return;
+    if (typeof window === 'undefined' || typeof window.gtag !== 'function') return;
+    if (getAnalyticsConsent() !== 'granted') return;
+
+    const raw = parameters as unknown;
+    if (raw === null || typeof raw !== 'object' || Array.isArray(raw)) return;
+    const rawRecord = raw as Record<string, unknown>;
+
+    for (const key of Object.keys(rawRecord)) {
+      if (DENIED_PARAM_KEYS.has(key)) return;
+    }
+
+    const schema = EVENT_SCHEMAS[name];
+    const sanitized: Record<string, string> = {};
+    for (const key of Object.keys(schema)) {
+      const value = rawRecord[key];
+      if (typeof value !== 'string') return;
+      if (!isSafeGenericValue(value)) return;
+      if (!schema[key](value)) return;
+      sanitized[key] = value;
+    }
+
+    window.gtag('event', name, sanitized);
+  } catch {
+    // Never throw into the UI — a broken analytics call must not break the product.
+  }
+}
