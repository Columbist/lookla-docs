+def test_openapi_salon_map_item_schema_has_all_fields_required():
+    # app/main.py only serves /api/openapi.json when ENVIRONMENT != "production"
+    # (this deployment's .env and the Settings default both set/default to
+    # "production"), so the route itself is unreachable in every context this
+    # suite runs in. Generate the schema directly via app.openapi() instead —
+    # same schema-generation code path, independent of that deployment gate.
+    #
+    # All ten SalonMapItem fields must be present (though nullable) in every
+    # item — see test_map_item_has_documented_fields above — so the schema
+    # must list all ten as required, not just the non-Optional ones.
+    schema = app.openapi()
+    salon_map_item = schema["components"]["schemas"]["SalonMapItem"]
+    expected_fields = {
+        "id", "name", "slug", "lat", "lng", "address_city",
+        "phone_primary", "rating_google", "primary_photo", "is_open_now",
+    }
+    assert set(salon_map_item["properties"].keys()) == expected_fields
+    assert set(salon_map_item.get("required", [])) == expected_fields
+
+
