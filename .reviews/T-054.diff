index 0000000..7b80f14
--- /dev/null
+++ b/frontend/lib/searchContext.ts
@@ -0,0 +1,186 @@
+// T-054: canonical effective-filter model for the search results page —
+// pure, dependency-free (no React, no browser globals) so it's directly
+// unit-testable and the single source of truth both the results-summary
+// chips and the URL-mutation (remove/clear) logic build on.
+import type { Locale } from '@/i18n/request';
+import type { AreaItem, Category } from '@/lib/api';
+import { getAreaName, findAreaBySlug, buildAreaUrlParams } from '@/lib/areaFilter';
+
+export type ActiveSearchFilter =
+  | { type: 'query'; value: string; label: string }
+  | { type: 'area'; value: string; label: string }
+  | { type: 'legacy_city'; value: string; label: string }
+  | { type: 'category'; value: string; label: string }
+  | { type: 'min_rating'; value: string; label: string };
+
+export interface RawSearchState {
+  area: string;
+  city: string;
+  q: string;
+  category: string;
+  minRating: string;
+}
+
+export interface FilterTypeLabels {
+  area: string;
+  legacy_city: string;
+  category: string;
+  query: string;
+  min_rating: string;
+}
+
+const KNOWN_MIN_RATINGS = new Set(['3', '4', '4.5']);
+
+/**
+ * Light, locale-agnostic fallback label for a slug whose canonical metadata
+ * (areas/categories) hasn't loaded yet — "athens-center" -> "Athens Center".
+ * Used only until the real list arrives; see resolveSlugLabel below. Kept
+ * separate from CSS truncation, which is a rendering concern, not a data one.
+ */
+export function humanizeSlug(slug: string): string {
+  return slug
+    .split('-')
+    .filter(Boolean)
+    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
+    .join(' ');
+}
+
+interface SlugResolution {
+  /** true once the canonical list has loaded, regardless of whether a match was found */
+  resolved: boolean;
+  /** the label to show, or null if the filter must not be shown at all (resolved + no match = invalid) */
+  label: string | null;
+}
+
+function resolveSlugLabel(slug: string, canonicalLoaded: boolean, matchName: string | undefined): SlugResolution {
+  if (!canonicalLoaded) {
+    // Not yet loaded — show a readable guess derived purely from already-
+    // available URL state, rather than waiting on a fetch (avoids an
+    // avoidable hydration delay), and never the raw un-humanized slug.
+    return { resolved: false, label: humanizeSlug(slug) };
+  }
+  if (matchName === undefined) {
+    // Loaded, and the slug doesn't correspond to anything real — genuinely
+    // invalid; never show a misleading chip for it.
+    return { resolved: true, label: null };
+  }
+  return { resolved: true, label: matchName };
+}
+
+/**
+ * Derives the list of effective (i.e. actually applied) search filters from
+ * raw URL state, for display as chips and as input to the URL-mutation
+ * helpers below. Order matches the UI's left-to-right chip order.
+ */
+export function deriveActiveFilters(
+  raw: RawSearchState,
+  areas: AreaItem[],
+  categories: Category[],
+  locale: Locale,
+  labels: FilterTypeLabels,
+): ActiveSearchFilter[] {
+  const filters: ActiveSearchFilter[] = [];
+
+  const q = raw.q.trim();
+  if (q) {
+    filters.push({ type: 'query', value: q, label: `${labels.query}: ${q}` });
+  }
+
+  const area = raw.area.trim();
+  const city = raw.city.trim();
+
+  if (area) {
+    const match = findAreaBySlug(areas, area);
+    const matchName = match ? getAreaName(match, locale) : undefined;
+    const { label } = resolveSlugLabel(area, areas.length > 0, matchName);
+    if (label !== null) {
+      filters.push({ type: 'area', value: area, label: `${labels.area}: ${label}` });
+    }
+  } else if (city) {
+    // Canonical `area` is authoritative when present — city is only ever
+    // shown as its own filter when there is no area to supersede it, so a
+    // user is never silently filtered by a hidden legacy param.
+    filters.push({ type: 'legacy_city', value: city, label: `${labels.legacy_city}: ${city}` });
+  }
+
+  const category = raw.category.trim();
+  if (category) {
+    const match = categories.find(c => c.slug === category);
+    const { label } = resolveSlugLabel(category, categories.length > 0, match?.name);
+    if (label !== null) {
+      filters.push({ type: 'category', value: category, label: `${labels.category}: ${label}` });
+    }
+  }
+
+  const minRating = raw.minRating.trim();
+  if (minRating && KNOWN_MIN_RATINGS.has(minRating)) {
+    filters.push({ type: 'min_rating', value: minRating, label: `${labels.min_rating}: ${minRating}+` });
+  }
+
+  return filters;
+}
+
+/** Always resets pagination — the result set changes whenever any filter changes. */
+function withoutPage(params: URLSearchParams): URLSearchParams {
+  const next = new URLSearchParams(params);
+  next.delete('page');
+  return next;
+}
+
+export function removeQueryFilter(current: URLSearchParams): URLSearchParams {
+  const next = withoutPage(current);
+  next.delete('q');
+  return next;
+}
+
+export function removeAreaFilter(current: URLSearchParams): URLSearchParams {
+  // Reuses T-007's buildAreaUrlParams — touching the Area control (including
+  // clearing it) already deletes the legacy `city` param too, so it cannot
+  // silently become active again after area removal.
+  return buildAreaUrlParams(current, '');
+}
+
+export function removeLegacyCityFilter(current: URLSearchParams): URLSearchParams {
+  const next = withoutPage(current);
+  next.delete('city');
+  return next;
+}
+
+export function removeCategoryFilter(current: URLSearchParams): URLSearchParams {
+  const next = withoutPage(current);
+  next.delete('category');
+  return next;
+}
+
+export function removeMinRatingFilter(current: URLSearchParams): URLSearchParams {
+  const next = withoutPage(current);
+  next.delete('min_rating');
+  return next;
+}
+
+export function removeActiveFilter(current: URLSearchParams, filter: ActiveSearchFilter): URLSearchParams {
+  switch (filter.type) {
+    case 'query': return removeQueryFilter(current);
+    case 'area': return removeAreaFilter(current);
+    case 'legacy_city': return removeLegacyCityFilter(current);
+    case 'category': return removeCategoryFilter(current);
+    case 'min_rating': return removeMinRatingFilter(current);
+  }
+}
+
+/**
+ * Removes every effective search/filter parameter — area, legacy city,
+ * query, category, min_rating — and pagination. Preserves everything else
+ * verbatim (view, and any future/unrelated param), matching the same
+ * preserve-by-default pattern already used throughout this file rather than
+ * an allowlist that would need updating for every new unrelated param.
+ */
+export function clearAllActiveFilters(current: URLSearchParams): URLSearchParams {
+  const next = withoutPage(current);
+  next.delete('area');
+  next.delete('city');
+  next.delete('q');
+  next.delete('category');
+  next.delete('min_rating');
+  return next;
+}
