+import { test, describe } from 'node:test';
+import assert from 'node:assert/strict';
+import fs from 'node:fs';
+import path from 'node:path';
+import { fileURLToPath } from 'node:url';
+
+const here = path.dirname(fileURLToPath(import.meta.url));
+const source = fs.readFileSync(path.join(here, 'useFilterChipFocus.ts'), 'utf-8');
+
+describe('T-054: useFilterChipFocus', () => {
+  test('only acts when a removal was explicitly marked AND the count actually changed — never on an unrelated render', () => {
+    const effectBody = source.slice(source.indexOf('useEffect(() => {'), source.indexOf('}, [filterCount]);'));
+    assert.ok(effectBody.includes('pendingIndexRef.current !== null && prevCountRef.current !== filterCount'));
+  });
+
+  test('resets the pending flag before acting, so it cannot fire twice for one removal', () => {
+    const effectBody = source.slice(source.indexOf('useEffect(() => {'), source.indexOf('}, [filterCount]);'));
+    const resetIdx = effectBody.indexOf('pendingIndexRef.current = null;');
+    const focusIdx = effectBody.indexOf('.focus()');
+    assert.ok(resetIdx > -1 && focusIdx > -1 && resetIdx < focusIdx);
+  });
+
+  test('priority order: next chip at the same index, then clear-all, then the summary region', () => {
+    const effectBody = source.slice(source.indexOf('useEffect(() => {'), source.indexOf('}, [filterCount]);'));
+    const nextChipIdx = effectBody.indexOf('nextChip.focus()');
+    const clearAllIdx = effectBody.indexOf('clearAllRef.current.focus()');
+    const summaryIdx = effectBody.indexOf('summaryRef.current?.focus()');
+    assert.ok(nextChipIdx > -1 && clearAllIdx > -1 && summaryIdx > -1);
+    assert.ok(nextChipIdx < clearAllIdx && clearAllIdx < summaryIdx);
+  });
+
+  test('the "next chip" lookup is scoped to data-chip-index within the container, not a global document query', () => {
+    assert.ok(source.includes('containerRef.current?.querySelector<HTMLButtonElement>(`[data-chip-index="${idx}"]`)'));
+  });
+
+  test('markRemoval accepts an out-of-range index (e.g. -1) as the documented clear-all signal', () => {
+    assert.ok(/"clear all".*never matches a real chip/s.test(source) || source.includes('out-of-range value (e.g. -1) for "clear all"'));
+  });
+
+  test('exposes exactly the 4 refs + markRemoval a caller needs, nothing else', () => {
+    assert.ok(source.includes('return { containerRef, clearAllRef, summaryRef, markRemoval };'));
+  });
+});
diff --git a/frontend/lib/useFilterChipFocus.ts b/frontend/lib/useFilterChipFocus.ts
new file mode 100644
index 0000000..da249cc
--- /dev/null
+++ b/frontend/lib/useFilterChipFocus.ts
@@ -0,0 +1,50 @@
+'use client';
+import { useEffect, useRef } from 'react';
+
+/**
+ * T-054: after a user removes an active-filter chip (or clears all), moves
+ * focus predictably rather than letting it fall to <body> once the clicked
+ * button's own DOM node is gone (same class of problem T-042 solved for
+ * Retry). Priority: the chip that shifted into the removed one's index
+ * (i.e. "the next chip"), then the clear-all button, then the results
+ * summary region itself.
+ *
+ * `markRemoval(index)` must be called synchronously in the same event
+ * handler that triggers the URL mutation, BEFORE the navigation resolves —
+ * it only records intent; the actual focus move happens once `filterCount`
+ * (computed from the post-navigation URL state) is observed to differ,
+ * confirming the removal actually took effect. This is also what prevents
+ * an unrelated render (e.g. the initial mount, or an ordinary search
+ * finishing loading) from ever moving focus: without an explicit pending
+ * mark, the effect below never fires.
+ */
+export function useFilterChipFocus(filterCount: number) {
+  const containerRef = useRef<HTMLUListElement>(null);
+  const clearAllRef = useRef<HTMLButtonElement>(null);
+  const summaryRef = useRef<HTMLDivElement>(null);
+  const pendingIndexRef = useRef<number | null>(null);
+  const prevCountRef = useRef(filterCount);
+
+  useEffect(() => {
+    if (pendingIndexRef.current !== null && prevCountRef.current !== filterCount) {
+      const idx = pendingIndexRef.current;
+      pendingIndexRef.current = null;
+      const nextChip = containerRef.current?.querySelector<HTMLButtonElement>(`[data-chip-index="${idx}"]`);
+      if (nextChip) {
+        nextChip.focus();
+      } else if (clearAllRef.current) {
+        clearAllRef.current.focus();
+      } else {
+        summaryRef.current?.focus();
+      }
+    }
+    prevCountRef.current = filterCount;
+  }, [filterCount]);
+
+  /** Call with the removed chip's index; use any out-of-range value (e.g. -1) for "clear all", which never matches a real chip and so always falls through to clear-all-or-summary. */
+  function markRemoval(index: number): void {
+    pendingIndexRef.current = index;
+  }
+
+  return { containerRef, clearAllRef, summaryRef, markRemoval };
+}
