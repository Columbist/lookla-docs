+import { test, describe } from 'node:test';
+import assert from 'node:assert/strict';
+import fs from 'node:fs';
+import path from 'node:path';
+import { fileURLToPath } from 'node:url';
+import { IntlMessageFormat } from 'intl-messageformat';
+
+const here = path.dirname(fileURLToPath(import.meta.url));
+const frontendRoot = path.join(here, '..');
+
+function messagesFor(locale: string) {
+  return JSON.parse(fs.readFileSync(path.join(frontendRoot, 'messages', `${locale}.json`), 'utf-8'));
+}
+
+function format(locale: string, count: number): string {
+  const msg = messagesFor(locale).search.results_summary;
+  const fmt = new IntlMessageFormat(msg, locale);
+  return fmt.format({ count }) as string;
+}
+
+describe('T-054: search.results_summary — locale-aware pluralization', () => {
+  test('10. successful total 0 -> localized zero state (en)', () => {
+    assert.equal(format('en', 0), 'No salons found');
+  });
+
+  test('11. successful total 1 -> singular (en)', () => {
+    assert.equal(format('en', 1), '1 salon found');
+  });
+
+  test('12. successful total >1 -> correct plural (en)', () => {
+    assert.equal(format('en', 24), '24 salons found');
+    assert.equal(format('en', 2), '2 salons found');
+  });
+
+  test('13. Russian plural cases (one/few/many/other, including 21 -> one, not "many")', () => {
+    assert.equal(format('ru', 0), 'Салоны не найдены');
+    assert.equal(format('ru', 1), '1 салон найден');
+    assert.equal(format('ru', 2), '2 салона найдено');
+    assert.equal(format('ru', 3), '3 салона найдено');
+    assert.equal(format('ru', 4), '4 салона найдено');
+    assert.equal(format('ru', 5), '5 салонов найдено');
+    assert.equal(format('ru', 11), '11 салонов найдено');
+    assert.equal(format('ru', 21), '21 салон найден');
+    assert.equal(format('ru', 25), '25 салонов найдено');
+  });
+
+  test('14. Ukrainian plural cases (one/few/many/other)', () => {
+    assert.equal(format('uk', 0), 'Салонів не знайдено');
+    assert.equal(format('uk', 1), '1 салон знайдено');
+    assert.equal(format('uk', 2), '2 салони знайдено');
+    assert.equal(format('uk', 3), '3 салони знайдено');
+    assert.equal(format('uk', 4), '4 салони знайдено');
+    assert.equal(format('uk', 5), '5 салонів знайдено');
+    assert.equal(format('uk', 11), '11 салонів знайдено');
+    assert.equal(format('uk', 21), '21 салон знайдено');
+  });
+
+  test('Greek one/other cases', () => {
+    assert.equal(format('el', 0), 'Δεν βρέθηκαν σαλόνια');
+    assert.equal(format('el', 1), 'Βρέθηκε 1 σαλόνι');
+    assert.equal(format('el', 2), 'Βρέθηκαν 2 σαλόνια');
+  });
+
+  test('does not concatenate translated fragments — the whole sentence is one ICU message per locale', () => {
+    for (const locale of ['en', 'el', 'ru', 'uk']) {
+      const msg = messagesFor(locale).search.results_summary;
+      assert.ok(msg.includes('{count, plural,'), `${locale}.json search.results_summary must be a single ICU plural message`);
+    }
+  });
+
+  test('results_heading exists and is non-empty in all 4 locales', () => {
+    for (const locale of ['en', 'el', 'ru', 'uk']) {
+      const heading = messagesFor(locale).search.results_heading;
+      assert.ok(typeof heading === 'string' && heading.trim().length > 0, `${locale}.json search.results_heading missing/empty`);
+    }
+  });
+
+  test('the old unused results_count key was removed, not left as dead duplicate state', () => {
+    for (const locale of ['en', 'el', 'ru', 'uk']) {
+      assert.ok(!('results_count' in messagesFor(locale).search), `${locale}.json should not still have the old dead results_count key`);
+    }
+  });
+
+  test('search namespace keys remain identical across all four locales after these additions', () => {
+    const keySets = ['el', 'en', 'ru', 'uk'].map(locale => Object.keys(messagesFor(locale).search).sort());
+    for (let i = 1; i < keySets.length; i++) {
+      assert.deepEqual(keySets[i], keySets[0]);
+    }
+  });
+});
