@@ -0,0 +1,42 @@
+'use client';
+import type { ActiveSearchFilter } from '@/lib/searchContext';
+
+interface Props {
+  filters: ActiveSearchFilter[];
+  onRemove: (filter: ActiveSearchFilter, index: number) => void;
+  removeLabel: (filter: ActiveSearchFilter) => string;
+  containerRef: React.RefObject<HTMLUListElement>;
+}
+
+/**
+ * T-054: one real <button> per chip, no nested interactive controls, no
+ * chip-as-button — the chip itself is a plain <li>, only the × control is
+ * interactive. `data-chip-index` is read by useFilterChipFocus to find
+ * "the next chip" after a removal shifts the array; it is not used for
+ * anything else and carries no semantic meaning of its own.
+ */
+export default function ActiveFilterChips({ filters, onRemove, removeLabel, containerRef }: Props) {
+  if (filters.length === 0) return null;
+
+  return (
+    <ul ref={containerRef} className="flex flex-wrap gap-2 mt-2" aria-label="Active filters">
+      {filters.map((filter, index) => (
+        <li
+          key={`${filter.type}:${filter.value}`}
+          className="flex items-center gap-1.5 bg-pink-50 text-pink-700 text-sm pl-3 pr-2 py-1.5 rounded-full max-w-full"
+        >
+          <span className="truncate max-w-[220px]" title={filter.label}>{filter.label}</span>
+          <button
+            type="button"
+            data-chip-index={index}
+            onClick={() => onRemove(filter, index)}
+            aria-label={removeLabel(filter)}
+            className="shrink-0 text-pink-500 hover:text-pink-800 font-bold leading-none w-4 h-4 flex items-center justify-center"
+          >
+            ×
+          </button>
+        </li>
+      ))}
+    </ul>
+  );
+}
