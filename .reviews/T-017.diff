@@ -0,0 +1,124 @@
+import { test, describe } from 'node:test';
+import assert from 'node:assert/strict';
+import fs from 'node:fs';
+import path from 'node:path';
+import { fileURLToPath } from 'node:url';
+import { PRIVACY_CONTENT } from '../app/[locale]/privacy/content';
+
+const here = path.dirname(fileURLToPath(import.meta.url));
+const frontendRoot = path.join(here, '..');
+const LOCALES = ['el', 'en', 'ru', 'uk'] as const;
+
+describe('T-017: Privacy Policy page exists and is SSR', () => {
+  test('page.tsx exists at app/[locale]/privacy/page.tsx', () => {
+    const pagePath = path.join(frontendRoot, 'app', '[locale]', 'privacy', 'page.tsx');
+    assert.ok(fs.existsSync(pagePath), 'privacy page.tsx must exist');
+  });
+
+  test('page.tsx has no "use client" directive — confirms it is a server component (SSR)', () => {
+    const source = fs.readFileSync(path.join(frontendRoot, 'app', '[locale]', 'privacy', 'page.tsx'), 'utf-8');
+    assert.ok(!source.includes("'use client'"), 'privacy page must be a server component, not client-rendered');
+  });
+
+  test('page.tsx exports a default async component reading params.locale (App Router page contract)', () => {
+    const source = fs.readFileSync(path.join(frontendRoot, 'app', '[locale]', 'privacy', 'page.tsx'), 'utf-8');
+    assert.ok(source.includes('export default async function PrivacyPage'), 'must export a PrivacyPage server component');
+  });
+});
+
+describe('T-017: Privacy Policy content covers all 4 locales', () => {
+  for (const locale of LOCALES) {
+    test(`${locale} content exists and is non-empty`, () => {
+      const content = PRIVACY_CONTENT[locale];
+      assert.ok(content, `content for locale ${locale} must exist`);
+      assert.ok(content.title.length > 0);
+      assert.ok(content.lastUpdated.length > 0);
+      assert.ok(content.intro.length > 0);
+      assert.ok(content.sections.length > 0);
+    });
+
+    test(`${locale} every section has a heading and at least one non-empty paragraph`, () => {
+      const content = PRIVACY_CONTENT[locale];
+      for (const section of content.sections) {
+        assert.ok(section.heading.length > 0);
+        assert.ok(section.paragraphs.length > 0);
+        for (const p of section.paragraphs) {
+          assert.ok(p.trim().length > 0, `empty paragraph found in section "${section.heading}" (${locale})`);
+        }
+      }
+    });
+  }
+
+  test('all 4 locales have the same number of sections (structural parity)', () => {
+    const counts = LOCALES.map(l => PRIVACY_CONTENT[l].sections.length);
+    assert.ok(counts.every(c => c === counts[0]), `section counts differ across locales: ${JSON.stringify(counts)}`);
+  });
+});
+
+describe('T-017: does not overstate data collection (per audit findings)', () => {
+  const allText = LOCALES.map(l => JSON.stringify(PRIVACY_CONTENT[l])).join('\n');
+
+  test('does not claim 90-day log retention (verified live config is 14 days)', () => {
+    assert.ok(!allText.includes('90 day') && !allText.includes('90-day'), 'must not repeat the stale 90-day retention claim');
+  });
+
+  test('states the verified 14-day nginx log retention in every locale', () => {
+    for (const locale of LOCALES) {
+      const text = JSON.stringify(PRIVACY_CONTENT[locale]);
+      assert.ok(text.includes('14'), `${locale} content should reference the verified 14-day log retention`);
+    }
+  });
+
+  test('does not claim GA4 / Google Analytics is in use', () => {
+    assert.ok(!/we use google analytics/i.test(allText));
+    assert.ok(!/we use ga4/i.test(allText));
+  });
+
+  test('does not flatly claim "no location data" / "no GPS" (browser Geolocation API is used client-side)', () => {
+    assert.ok(!/no location tracking/i.test(allText));
+    assert.ok(!/we do not collect location/i.test(allText));
+  });
+
+  test('does not claim offsite/geo-redundant backups are active (rclone is not installed; backups are local-only today)', () => {
+    assert.ok(!/offsite backup/i.test(allText) || /not active|planned but not active/i.test(allText));
+  });
+});
+
+describe('T-017: does not invent undefined legal bases (per explicit instruction)', () => {
+  const allText = LOCALES.map(l => JSON.stringify(PRIVACY_CONTENT[l])).join('\n');
+  const forbiddenLegalTerms = ['legitimate interest', 'legal obligation', 'contractual necessity', 'legal basis'];
+
+  for (const term of forbiddenLegalTerms) {
+    test(`does not assert an undefined legal basis: "${term}"`, () => {
+      assert.ok(!new RegExp(term, 'i').test(allText), `must not invent "${term}" without a business/legal decision`);
+    });
+  }
+
+  test('marks undefined business/legal points with the literal TODO marker, in every locale', () => {
+    for (const locale of LOCALES) {
+      const text = JSON.stringify(PRIVACY_CONTENT[locale]);
+      assert.ok(text.includes('TODO (requires business/legal decision)'), `${locale} must flag undecided points with the literal TODO marker`);
+    }
+  });
+});
+
+describe('T-017: messaging/booking PII disclosure present (per the live /account/messages + /api/chat audit finding)', () => {
+  test('English content discloses in-app messaging data collection', () => {
+    const text = JSON.stringify(PRIVACY_CONTENT.en);
+    assert.ok(/messag/i.test(text), 'must disclose in-app messaging as a real, live data flow');
+  });
+
+  test('English content discloses availability-request / appointment name+phone collection', () => {
+    const text = JSON.stringify(PRIVACY_CONTENT.en);
+    assert.ok(/appointment/i.test(text) && /phone/i.test(text));
+  });
+});
+
+describe('T-017: contact email present and consistent', () => {
+  for (const locale of LOCALES) {
+    test(`${locale} references hello@lookla.gr`, () => {
+      const text = JSON.stringify(PRIVACY_CONTENT[locale]);
+      assert.ok(text.includes('hello@lookla.gr'), `${locale} must include the contact email`);
+    });
+  }
+});
