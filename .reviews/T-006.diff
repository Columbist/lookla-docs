@@ -598,3 +599,68 @@ def get_district_by_area_slug(slug: str) -> str | None:
     if not slug:
         return None
     return AREA_SLUG_TO_DISTRICT.get(slug.strip().lower())
+
+
+def normalize_district_query(value: str | None) -> str:
+    """Normalize a free-text district query for alias lookup: trims
+    surrounding whitespace, applies Unicode NFKC normalization, collapses
+    repeated internal whitespace, and casefolds (Unicode-aware, so it
+    handles Cyrillic correctly unlike .lower()). Returns "" for empty
+    input. No transliteration — this only normalizes, it does not map
+    between scripts.
+    """
+    if not value:
+        return ""
+    normalized = unicodedata.normalize("NFKC", value.strip())
+    return " ".join(normalized.split()).casefold()
+
+
+def _build_district_query_aliases() -> dict[str, str]:
+    """Builds the normalized-alias -> canonical-district lookup from
+    AREA_METADATA (name_ru, name_uk, name_el, name_en, slug, and the
+    canonical district value itself). Raises ValueError at import time if
+    two different districts would normalize to the same alias — this must
+    never happen silently.
+    """
+    aliases: dict[str, str] = {}
+    for district, meta in AREA_METADATA.items():
+        candidates = {
+            meta["name_ru"], meta["name_uk"], meta["name_el"], meta["name_en"],
+            meta["slug"], district,
+        }
+        for candidate in candidates:
+            key = normalize_district_query(candidate)
+            if not key:
+                continue
+            existing = aliases.get(key)
+            if existing is not None and existing != district:
+                raise ValueError(
+                    f"District query alias collision: normalized key {key!r} "
+                    f"maps to both {existing!r} and {district!r}"
+                )
+            aliases[key] = district
+    return aliases
+
+
+# Reverse lookup: normalized localized district name/slug -> canonical
+# address_district value. Built once at import time (see
+# _build_district_query_aliases and test_district_alias_table_builds_without_collision).
+DISTRICT_QUERY_ALIASES: dict[str, str] = _build_district_query_aliases()
+
+
+def resolve_district_query(value: str | None) -> str | None:
+    """Resolve a complete localized district name (e.g. "Глифада",
+    "Гліфада", "Glyfada", "glyfada") to its canonical address_district
+    value, or None if the (normalized) value isn't a known district alias.
+
+    This is for exact whole-query location intent (T-006) — it does not
+    do substring/fuzzy matching or combined service+location parsing.
+    Case/whitespace-insensitive via normalize_district_query. Performs no
+    database query and no external calls — pure in-memory lookup.
+    """
+    if not value:
+        return None
+    key = normalize_district_query(value)
+    if not key:
+        return None
+    return DISTRICT_QUERY_ALIASES.get(key)
