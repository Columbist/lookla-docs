+// T-055: word used inside the card's accessible name — not the visible
+// "Rating" filter label (search namespace), a short mid-sentence noun.
+const RATING_WORD: Record<string, string> = {
+  el: 'βαθμολογία', en: 'rating', ru: 'рейтинг', uk: 'рейтинг',
+};
+
+/**
+ * T-055: builds the whole-card <Link>'s accessible name. Deliberately NOT
+ * a transcript of the visible content — no star glyphs (screen readers
+ * announce them as literal Unicode character names), no review count, no
+ * raw street address. Found via live audit that without an explicit
+ * aria-label, the computed accessible name was the raw concatenation of
+ * every text node with no separators at all, e.g.
+ * "OpenΚουρείο JUST HAIRΕιρήνης 15, Πειραιάς★★★★★5.0(520)" — unusable for
+ * screen reader users. This is a short, well-punctuated summary sufficient
+ * to distinguish and select a card: name, city, rating, open status —
+ * each clause included only when the underlying data is actually present.
+ */
+export function buildCardAriaLabel(params: {
+  name: string;
+  city?: string;
+  rating?: string;
+  statusLabel?: string;
+  locale: string;
+}): string {
+  const ratingWord = RATING_WORD[params.locale] ?? RATING_WORD.en;
+  return [
+    params.name,
+    params.city || undefined,
+    params.rating ? `${ratingWord} ${params.rating}` : undefined,
+    params.statusLabel,
+  ].filter(Boolean).join(', ');
+}
+
