+    data = resp.json()
+    assert data["total"] == 2
+    assert all("Glyfada" in item["address_city"] for item in data["items"])
+
+
+def test_list_area_takes_precedence_over_city(client):
+    resp = client.get("/api/salons", params={"area": "glyfada", "city": "Athens"})
+    data = resp.json()
+    assert data["total"] == 2
+    assert all(item["address_city"] == "Glyfada" for item in data["items"])
