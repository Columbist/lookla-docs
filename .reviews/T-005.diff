+"""
+T-005: `?area=` filter on GET /api/salons and GET /api/salons/map.
+
+Uses FastAPI TestClient with SQLite in-memory DB via dependency override.
+No connection to production. Behaviour is tested through the API and query
+results, not via source-code substring inspection.
+"""
+import inspect
+
+import pytest
+from fastapi.testclient import TestClient
+from sqlalchemy import create_engine, event
+from sqlalchemy.orm import sessionmaker
+from sqlalchemy.pool import StaticPool
+
+from app.main import app
+from app.core.database import get_db, Base
+from app.models.salon import Salon
+from app.data.area_metadata import AREA_METADATA, AREA_SLUG_TO_DISTRICT, get_district_by_area_slug
+import app.routers.salons as salons_module
+
+
+# ── Test DB fixture ───────────────────────────────────────────────────────────
+# StaticPool forces all connections to reuse the same underlying DBAPI
+# connection so the tables created here are visible during request handling.
+# Base.metadata.create_all mirrors the real schema exactly (salons, photos,
+# services, salon_hours, ...) since app.models.salon registers every table
+# on import — avoids drift between a hand-written test schema and the ORM.
+
+def _build_test_engine():
+    engine = create_engine(
+        "sqlite:///:memory:",
+        connect_args={"check_same_thread": False},
+        poolclass=StaticPool,
+    )
+    Base.metadata.create_all(engine)
+    return engine
+
+
+# Seed data. "Nea Kallithea" is deliberately a superstring of the "Kallithea"
+# district to prove area filtering uses exact equality, not substring/ILIKE
+# matching, on the resolved canonical district.
+SEED_SALONS = [
+    dict(name="Glyfada Nails", slug="glyfada-nails", address_city="Glyfada",
+         address_district="Glyfada", lat=37.86, lng=23.75, is_active=True,
+         rating_google=4.7, rating_count=10, description="best nail salon"),
+    dict(name="Glyfada Hair", slug="glyfada-hair", address_city="Glyfada",
+         address_district="Glyfada", lat=37.87, lng=23.76, is_active=True,
+         rating_google=4.5, rating_count=20, description="great hair salon"),
+    dict(name="Glyfada Inactive", slug="glyfada-inactive", address_city="Glyfada",
+         address_district="Glyfada", lat=37.88, lng=23.77, is_active=False,
+         rating_google=4.9, rating_count=5, description="closed down"),
+    dict(name="Athens Center Nails", slug="athens-center-nails", address_city="Athens",
+         address_district="Athens Center", lat=37.98, lng=23.73, is_active=True,
+         rating_google=4.2, rating_count=8, description="nail bar in the center"),
+    dict(name="Kallithea Barber", slug="kallithea-barber", address_city="Kallithea",
+         address_district="Kallithea", lat=37.95, lng=23.70, is_active=True,
+         rating_google=4.0, rating_count=3, description="barbershop"),
+    dict(name="Nea Kallithea Salon", slug="nea-kallithea-salon", address_city="Kallithea",
+         address_district="Nea Kallithea", lat=37.94, lng=23.69, is_active=True,
+         rating_google=4.8, rating_count=2, description="unrelated district"),
+    dict(name="No District Salon", slug="no-district-salon", address_city="Athens",
+         address_district=None, lat=37.90, lng=23.70, is_active=True,
+         rating_google=3.5, rating_count=1, description="unmapped district"),
+]
+
+
+@pytest.fixture(scope="module")
+def client():
+    engine = _build_test_engine()
+    test_session_local = sessionmaker(autocommit=False, autoflush=False, bind=engine)
+
+    session = test_session_local()
+    for row in SEED_SALONS:
+        session.add(Salon(**row))
+    session.commit()
+    session.close()
+
+    def override_get_db():
+        db = test_session_local()
+        try:
+            yield db
+        finally:
+            db.close()
+
+    previous_override = app.dependency_overrides.get(get_db)
+    app.dependency_overrides[get_db] = override_get_db
+
+    # _batch_primary_photos / _batch_min_prices / _batch_open_now issue raw
+    # Postgres-only SQL (DISTINCT ON, = ANY(...)) that SQLite can't execute.
+    # They're pre-existing, unrelated to the T-005 area filter under test, so
+    # they're stubbed out here rather than pulled into scope for this PR.
+    original_photos = salons_module._batch_primary_photos
+    original_prices = salons_module._batch_min_prices
+    original_open = salons_module._batch_open_now
+    salons_module._batch_primary_photos = lambda salon_ids, db: {}
+    salons_module._batch_min_prices = lambda salon_ids, db, name_keywords=None: {}
+    salons_module._batch_open_now = lambda salon_ids, db: {}
+
+    # No `with` block: TestClient(app) alone does not run the app's lifespan
+    # (see app/main.py check_db() startup check), which would otherwise
+    # require a real database connection unrelated to this endpoint's logic.
+    test_client = TestClient(app)
+    test_client.engine = engine  # exposed for query-count assertions below
+    try:
+        yield test_client
+    finally:
+        test_client.close()
+        salons_module._batch_primary_photos = original_photos
+        salons_module._batch_min_prices = original_prices
+        salons_module._batch_open_now = original_open
+        if previous_override is None:
+            app.dependency_overrides.pop(get_db, None)
+        else:
+            app.dependency_overrides[get_db] = previous_override
+        engine.dispose()
+
+
+def _query_count(client: TestClient, url: str) -> int:
+    statements = []
+
+    def _log(conn, cursor, statement, parameters, context, executemany):
+        statements.append(statement)
+
+    event.listen(client.engine, "before_cursor_execute", _log)
+    try:
+        resp = client.get(url)
+    finally:
+        event.remove(client.engine, "before_cursor_execute", _log)
+    assert resp.status_code == 200
+    return len(statements)
+
+
+# ── Slug resolution (pure function, no client) ────────────────────────────────
+
+def test_resolve_glyfada():
+    assert get_district_by_area_slug("glyfada") == "Glyfada"
+
+
+def test_resolve_athens_center():
+    assert get_district_by_area_slug("athens-center") == "Athens Center"
+
+
+def test_resolve_case_insensitive():
+    assert get_district_by_area_slug("GLYFADA") == "Glyfada"
+    assert get_district_by_area_slug("Glyfada") == "Glyfada"
+
+
+def test_resolve_surrounding_whitespace():
+    assert get_district_by_area_slug("  glyfada  ") == "Glyfada"
+
+
+def test_resolve_unknown_slug_returns_none():
+    assert get_district_by_area_slug("nonexistent-area") is None
+
+
+def test_resolve_empty_string_returns_none():
+    assert get_district_by_area_slug("") is None
+    assert get_district_by_area_slug("   ") is None
+
+
+def test_every_metadata_slug_resolves_back_to_its_district():
+    for district, meta in AREA_METADATA.items():
+        assert get_district_by_area_slug(meta["slug"]) == district
+
+
+def test_reverse_lookup_same_length_as_metadata():
+    assert len(AREA_SLUG_TO_DISTRICT) == len(AREA_METADATA)
+
+
+def test_resolver_takes_no_db_argument():
+    # Architectural guarantee: resolution must be a pure in-memory lookup,
+    # not something that could accidentally grow a DB round-trip later.
+    params = inspect.signature(get_district_by_area_slug).parameters
+    assert list(params) == ["slug"]
+
