+# Reverse lookup: public area slug -> canonical address_district value.
+# Built once at import time (metadata slugs are static and unique — see
+# test_metadata_slugs_unique in test_areas_endpoint.py).
+AREA_SLUG_TO_DISTRICT: dict[str, str] = {
+    metadata["slug"]: district
+    for district, metadata in AREA_METADATA.items()
+}
+
+
+def get_district_by_area_slug(slug: str) -> str | None:
+    """Resolve a public area slug (e.g. "athens-center") to its canonical
+    address_district value (e.g. "Athens Center"), or None if unknown.
+
+    Case-insensitive, strips surrounding whitespace. Performs no database
+    query and no external calls — pure in-memory lookup.
+    """
+    if not slug:
+        return None
+    return AREA_SLUG_TO_DISTRICT.get(slug.strip().lower())
