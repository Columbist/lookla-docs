+    assert data["total"] == 2
+
+
+def test_list_area_combines_with_q(client):
+    resp = client.get("/api/salons", params={"area": "glyfada", "q": "nail"})
+    data = resp.json()
+    assert data["total"] == 1
+    assert data["items"][0]["name"] == "Glyfada Nails"
+
+
+def test_list_area_combines_with_category(client):
+    resp = client.get("/api/salons", params={"area": "glyfada", "category": "nails"})
+    data = resp.json()
+    assert data["total"] == 1
+    assert data["items"][0]["name"] == "Glyfada Nails"
+
+
+def test_list_area_combines_with_min_rating(client):
+    resp = client.get("/api/salons", params={"area": "glyfada", "min_rating": 4.6})
+    data = resp.json()
+    assert data["total"] == 1
+    assert data["items"][0]["name"] == "Glyfada Nails"
+
+
+def test_list_area_pagination_total_reflects_filtered_area(client):
+    resp = client.get("/api/salons", params={"area": "glyfada", "limit": 1})
+    data = resp.json()
+    assert data["total"] == 2
+    assert len(data["items"]) == 1
+    assert data["pages"] == 2
+
+
+def test_list_area_excludes_inactive_salons(client):
+    resp = client.get("/api/salons", params={"area": "glyfada", "limit": 100})
+    names = {item["name"] for item in resp.json()["items"]}
+    assert "Glyfada Inactive" not in names
+
+
+# ── Map endpoint: area filter ─────────────────────────────────────────────────
+
+def test_map_area_filters_exact_district(client):
+    resp = client.get("/api/salons/map", params={"area": "glyfada"})
+    assert resp.status_code == 200
+    items = resp.json()
+    assert isinstance(items, list)  # existing map contract: bare list, unchanged by T-005
+    assert len(items) == 2
+    assert all(item["address_city"] == "Glyfada" for item in items)
+
+
+def test_map_unknown_area_returns_empty_list_not_404(client):
+    resp = client.get("/api/salons/map", params={"area": "unknown-area"})
