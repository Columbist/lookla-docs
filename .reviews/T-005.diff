+
+# ── Regression / query quality ────────────────────────────────────────────────
+
+def test_list_endpoint_is_public_no_auth_required(client):
+    resp = client.get("/api/salons", params={"area": "glyfada"})
+    assert resp.status_code == 200
+
+
+def test_map_endpoint_is_public_no_auth_required(client):
+    resp = client.get("/api/salons/map", params={"area": "glyfada"})
+    assert resp.status_code == 200
+
+
+def test_area_filter_adds_no_extra_query(client):
+    # Area resolution is a pure in-memory dict lookup (see
+    # test_resolver_takes_no_db_argument); the SQL query count with an area
+    # filter must equal the count without one — no extra round-trip to
+    # resolve the slug, and no N+1 introduced by the new filter branch.
+    without_area = _query_count(client, "/api/salons")
+    with_area = _query_count(client, "/api/salons?area=glyfada")
+    assert with_area == without_area
