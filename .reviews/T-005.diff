+def _apply_area_filter(query, area: Optional[str], city: Optional[str]):
+    """Apply the area (preferred) or legacy city filter to a Salon query.
+
+    `area` is a public district slug (see GET /api/areas) — it is resolved
+    to the canonical `address_district` value via AREA_SLUG_TO_DISTRICT and
+    matched with exact equality, never against raw DB text. `area` takes
+    precedence over `city` whenever it's supplied (including when it fails
+    to resolve — an unknown area does not fall back to city).
+    """
+    area = area.strip() if area else None
+    if area:
+        district = get_district_by_area_slug(area)
+        if district is None:
+            return query.filter(false())
+        return query.filter(Salon.address_district == district)
+    if city:
+        return query.filter(Salon.address_city.ilike(f"%{city}%"))
+    return query
