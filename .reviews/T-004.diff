+def test_metadata_has_no_duplicate_literal_keys():
+    """Detect duplicate dict keys via AST — runtime dict silently deduplicates."""
+    tree = ast.parse(AREA_METADATA_FILE.read_text())
+    for node in ast.walk(tree):
+        if isinstance(node, ast.Dict):
+            keys = [ast.literal_eval(k) for k in node.keys if k is not None]
+            seen: set = set()
+            for key in keys:
+                assert key not in seen, f"Duplicate key in area_metadata.py: '{key}'"
+                seen.add(key)
+
+
+def test_metadata_all_localized_names_non_empty():
+    for district, meta in AREA_METADATA.items():
+        for field in ("name_el", "name_en", "name_ru", "name_uk"):
+            assert meta[field].strip(), (
+                f"Empty {field} in AREA_METADATA[{district!r}]"
+            )
