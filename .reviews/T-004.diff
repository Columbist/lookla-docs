+"""
+T-004: GET /api/areas — behaviour tests.
+
+Uses FastAPI TestClient with SQLite in-memory DB via dependency override.
+No connection to production. No static source-code substring checks for
+behaviour that can be tested end-to-end.
+"""
+import pytest
+from fastapi.testclient import TestClient
+from sqlalchemy import create_engine, text
+from sqlalchemy.orm import sessionmaker, Session
+from sqlalchemy.pool import StaticPool
+
+from app.main import app
+from app.core.database import get_db
+from app.data.area_metadata import AREA_METADATA
+
+
+# ── Test DB fixture ───────────────────────────────────────────────────────────
+# StaticPool forces all connections to reuse the same underlying DBAPI
+# connection so the table created here is visible during request handling.
+
+TEST_ENGINE = create_engine(
+    "sqlite:///:memory:",
+    connect_args={"check_same_thread": False},
+    poolclass=StaticPool,
+)
+
+with TEST_ENGINE.connect() as conn:
+    conn.execute(text("""
+        CREATE TABLE salons (
+            id       INTEGER PRIMARY KEY AUTOINCREMENT,
+            address_district TEXT,
+            is_active INTEGER NOT NULL DEFAULT 1
+        )
+    """))
+    conn.execute(text("""
+        INSERT INTO salons (address_district, is_active) VALUES
+          ('Glyfada',       1),
+          ('Glyfada',       1),
+          ('Glyfada',       1),
+          ('Kallithea',     1),
+          ('Kallithea',     1),
+          ('Marousi',       1),
+          ('Athens Center', 1),
+          ('Glyfada',       0),  -- inactive: must not be counted
+          (NULL,            1),  -- null district: excluded
+          ('',              1),  -- empty district: excluded
+          ('   ',           1)   -- whitespace-only district: excluded
+    """))
+    conn.commit()
+
+TestSessionLocal = sessionmaker(autocommit=False, autoflush=False, bind=TEST_ENGINE)
+
+
+def override_get_db():
+    db = TestSessionLocal()
+    try:
+        yield db
+    finally:
+        db.close()
+
+
+app.dependency_overrides[get_db] = override_get_db
+client = TestClient(app)
+
+
+# ── Endpoint behaviour tests ──────────────────────────────────────────────────
+
+def test_areas_returns_200():
+    r = client.get("/api/areas")
+    assert r.status_code == 200
+
+
+def test_areas_root_key_is_items():
+    r = client.get("/api/areas")
+    data = r.json()
+    assert "items" in data
+    assert "areas" not in data
+
+
+def test_areas_item_shape():
+    r = client.get("/api/areas")
+    items = r.json()["items"]
+    assert len(items) > 0
+    required = {"slug", "name_el", "name_en", "name_ru", "name_uk", "salon_count", "region", "city"}
+    for item in items:
+        assert required == set(item.keys()), f"Item keys mismatch: {set(item.keys())}"
+
+
+def test_areas_counts_only_active_salons():
+    r = client.get("/api/areas")
+    items = r.json()["items"]
+    glyfada = next((i for i in items if i["slug"] == "glyfada"), None)
+    assert glyfada is not None
+    # 4 rows with Glyfada but 1 is inactive → expect 3
+    assert glyfada["salon_count"] == 3
+
+
+def test_areas_inactive_salons_excluded():
+    # 1 inactive Glyfada row: salon_count must be 3, not 4
+    r = client.get("/api/areas")
+    items = r.json()["items"]
+    glyfada = next(i for i in items if i["slug"] == "glyfada")
+    assert glyfada["salon_count"] == 3
+
+
+def test_areas_null_districts_excluded():
+    r = client.get("/api/areas")
+    items = r.json()["items"]
+    for item in items:
+        assert item["salon_count"] > 0
+
+
+def test_areas_empty_district_excluded():
+    r = client.get("/api/areas")
+    items = r.json()["items"]
+    # The "" row must not produce an area in the response
+    slugs = [i["slug"] for i in items]
+    # No item should have an empty or whitespace slug (those were excluded from DB query)
+    assert all(s.strip() for s in slugs)
+
+
+def test_areas_whitespace_district_excluded():
+    r = client.get("/api/areas")
+    items = r.json()["items"]
+    # Only 4 canonical districts have data in test DB
+    assert len(items) == 4
+
+
+def test_areas_zero_count_excluded():
+    # Test DB only has Glyfada, Kallithea, Marousi, Athens Center
+    # All other AREA_METADATA entries should be absent
+    r = client.get("/api/areas")
+    items = r.json()["items"]
+    slugs = {i["slug"] for i in items}
+    assert "piraeus" not in slugs  # no Piraeus salons in test DB
+    assert "kifissia" not in slugs
+
+
+def test_areas_grouped_by_canonical_district():
+    r = client.get("/api/areas")
+    items = r.json()["items"]
+    # Each district appears exactly once
+    slugs = [i["slug"] for i in items]
+    assert len(slugs) == len(set(slugs))
+
+
+def test_areas_region_filter_attica():
+    r = client.get("/api/areas?region=attica")
+    assert r.status_code == 200
+    items = r.json()["items"]
+    assert len(items) > 0
+    for item in items:
+        assert item["region"] == "attica"
+
+
+def test_areas_unknown_region_returns_empty():
+    r = client.get("/api/areas?region=unknown_xyz")
+    assert r.status_code == 200
+    assert r.json() == {"items": []}
+
+
+def test_areas_ordering_deterministic():
+    r = client.get("/api/areas")
+    items = r.json()["items"]
+    counts = [i["salon_count"] for i in items]
+    # Primary sort: salon_count descending
+    for i in range(len(counts) - 1):
+        if counts[i] == counts[i + 1]:
+            # Tie-breaker: name_en ascending
+            assert items[i]["name_en"] <= items[i + 1]["name_en"]
+        else:
+            assert counts[i] >= counts[i + 1]
+
+
+def test_areas_no_authentication_required():
+    # No auth headers — must still return 200
+    r = client.get("/api/areas", headers={})
+    assert r.status_code == 200
+
+
+def test_areas_registered_path_is_api_areas():
+    # Verify the route is at /api/areas by inspecting FastAPI's route list
+    paths = [route.path for route in app.routes]
+    assert "/api/areas" in paths
+
+
+def test_areas_not_under_categories_prefix():
+    paths = [route.path for route in app.routes]
+    assert "/api/categories/areas" not in paths
+
+
+def test_areas_no_conflicting_route_registrations():
+    # All /api/areas routes must resolve to the same handler
+    areas_routes = [r for r in app.routes if getattr(r, "path", "") == "/api/areas"]
+    assert len(areas_routes) == 1
+
+
+# ── Metadata integrity tests ──────────────────────────────────────────────────
+
+def test_metadata_slugs_unique():
+    slugs = [meta["slug"] for meta in AREA_METADATA.values()]
+    assert len(slugs) == len(set(slugs)), "Duplicate slugs in AREA_METADATA"
+
+
+def test_metadata_district_keys_unique():
+    keys = list(AREA_METADATA.keys())
+    assert len(keys) == len(set(keys)), "Duplicate keys in AREA_METADATA"
+
+
+def test_metadata_all_localized_names_non_empty():
+    for district, meta in AREA_METADATA.items():
+        for field in ("name_el", "name_en", "name_ru", "name_uk"):
+            assert meta[field].strip(), (
+                f"Empty {field} in AREA_METADATA[{district!r}]"
+            )
+
+
+def test_areas_single_aggregate_query(monkeypatch):
+    """Endpoint must execute one aggregate query, not one per area."""
+    query_count = 0
+    original_execute = Session.execute
+
+    def counting_execute(self, *args, **kwargs):
+        nonlocal query_count
+        query_count += 1
+        return original_execute(self, *args, **kwargs)
+
+    monkeypatch.setattr(Session, "execute", counting_execute)
+    client.get("/api/areas")
+    assert query_count == 1, (
+        f"Expected 1 DB query, got {query_count}. Check for N+1 in /api/areas."
+    )
