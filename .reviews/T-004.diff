+def test_areas_single_aggregate_query(client: TestClient, monkeypatch):
+    """Endpoint must execute one aggregate query, not one per area."""
+    query_count = 0
+    original_execute = Session.execute
+
+    def counting_execute(self, *args, **kwargs):
+        nonlocal query_count
+        query_count += 1
+        return original_execute(self, *args, **kwargs)
+
+    monkeypatch.setattr(Session, "execute", counting_execute)
+    client.get("/api/areas")
+    assert query_count == 1, (
+        f"Expected 1 DB query, got {query_count}. Check for N+1 in /api/areas."
+    )
+
