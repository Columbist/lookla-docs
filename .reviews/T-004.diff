+# ── Repository-level SQL exclusion tests ──────────────────────────────────────
+# get_active_salon_counts_by_district() is tested directly against rows whose
+# district is NOT a key in AREA_METADATA, so these assertions fail if any of
+# the SQL WHERE clauses (IS NOT NULL / trim <> '' / is_active) are removed —
+# they don't rely on AREA_METADATA silently discarding unknown keys.
+
+def _counts_for_rows(rows: list[tuple[str | None, int]]) -> dict[str, int]:
+    engine = create_engine(
+        "sqlite:///:memory:",
+        connect_args={"check_same_thread": False},
+        poolclass=StaticPool,
+    )
+    try:
+        with engine.connect() as conn:
+            conn.execute(text("""
+                CREATE TABLE salons (
+                    id INTEGER PRIMARY KEY AUTOINCREMENT,
+                    address_district TEXT,
+                    is_active INTEGER NOT NULL DEFAULT 1
+                )
+            """))
+            for district, is_active in rows:
+                conn.execute(
+                    text("INSERT INTO salons (address_district, is_active) VALUES (:d, :a)"),
+                    {"d": district, "a": is_active},
+                )
+            conn.commit()
+        session_local = sessionmaker(autocommit=False, autoflush=False, bind=engine)
+        db = session_local()
+        try:
+            return get_active_salon_counts_by_district(db)
+        finally:
+            db.close()
+    finally:
+        engine.dispose()
+
+
+def test_repo_excludes_null_district():
+    counts = _counts_for_rows([("Unmapped District", 1), (None, 1)])
+    assert None not in counts
+    assert counts == {"Unmapped District": 1}
+
+
+def test_repo_excludes_empty_district():
+    counts = _counts_for_rows([("Unmapped District", 1), ("", 1)])
+    assert "" not in counts
+    assert counts == {"Unmapped District": 1}
+
+
+def test_repo_excludes_whitespace_district():
+    counts = _counts_for_rows([("Unmapped District", 1), ("   ", 1)])
+    assert "   " not in counts
+    assert counts == {"Unmapped District": 1}
+
+
+def test_repo_excludes_inactive_salons():
+    counts = _counts_for_rows([("Unmapped District", 1), ("Unmapped District", 0)])
+    assert counts == {"Unmapped District": 1}
