+def get_active_salon_counts_by_district(db: Session) -> dict[str, int]:
+    """Active salon counts grouped by address_district.
+
+    Excludes NULL and blank (whitespace-only) districts and inactive salons.
+    """
+    rows = db.execute(text("""
+        SELECT address_district, COUNT(id) AS cnt
+        FROM salons
+        WHERE is_active = true
+          AND address_district IS NOT NULL
+          AND trim(address_district) <> ''
+        GROUP BY address_district
+    """)).fetchall()
+    return {row[0]: row[1] for row in rows}
