+"""
+T-004: GET /api/areas — behaviour tests.
+
+Uses FastAPI TestClient with SQLite in-memory DB via dependency override.
+No connection to production. No static source-code substring checks for
+behaviour that can be tested end-to-end.
+"""
+import ast
+import re
+from pathlib import Path
+
+import pytest
+from fastapi.testclient import TestClient
+from sqlalchemy import create_engine, text
+from sqlalchemy.orm import sessionmaker, Session
+from sqlalchemy.pool import StaticPool
+
+from app.main import app
+from app.core.database import get_db
+from app.data.area_metadata import AREA_METADATA, VALID_CITY_SLUGS
+from app.data.district_mapping import CITY_TO_DISTRICT
+from app.services.areas import get_active_salon_counts_by_district
+
+AREA_METADATA_FILE = Path(__file__).parent.parent / "app" / "data" / "area_metadata.py"
+METADATA_FIELDS = {"slug", "name_el", "name_en", "name_ru", "name_uk", "region", "city"}
+RESPONSE_ITEM_FIELDS = METADATA_FIELDS | {"salon_count"}
+VALID_REGIONS = {"attica"}
+SLUG_RE = re.compile(r"^[a-z0-9]+(?:-[a-z0-9]+)*$")
+
+
+# ── Test DB fixture ───────────────────────────────────────────────────────────
+# StaticPool forces all connections to reuse the same underlying DBAPI
+# connection so the table created here is visible during request handling.
+
+def _build_test_engine():
+    engine = create_engine(
+        "sqlite:///:memory:",
+        connect_args={"check_same_thread": False},
+        poolclass=StaticPool,
+    )
+    with engine.connect() as conn:
+        conn.execute(text("""
+            CREATE TABLE salons (
+                id       INTEGER PRIMARY KEY AUTOINCREMENT,
+                address_district TEXT,
+                is_active INTEGER NOT NULL DEFAULT 1
+            )
+        """))
+        conn.execute(text("""
+            INSERT INTO salons (address_district, is_active) VALUES
+              ('Glyfada',       1),
+              ('Glyfada',       1),
+              ('Glyfada',       1),
+              ('Kallithea',     1),
+              ('Kallithea',     1),
+              ('Marousi',       1),
+              ('Athens Center', 1),
+              ('Glyfada',       0),  -- inactive: must not be counted
+              (NULL,            1),  -- null district: excluded
+              ('',              1),  -- empty district: excluded
+              ('   ',           1)   -- whitespace-only district: excluded
+        """))
+        conn.commit()
+    return engine
+
+
+@pytest.fixture(scope="module")
+def client():
+    engine = _build_test_engine()
+    test_session_local = sessionmaker(autocommit=False, autoflush=False, bind=engine)
+
+    def override_get_db():
+        db = test_session_local()
+        try:
+            yield db
+        finally:
+            db.close()
+
+    previous_override = app.dependency_overrides.get(get_db)
+    app.dependency_overrides[get_db] = override_get_db
+
+    # No `with` block: TestClient(app) alone does not run the app's lifespan
+    # (see app/main.py check_db() startup check), which would otherwise
+    # require a real database connection unrelated to this endpoint's logic.
+    test_client = TestClient(app)
+    try:
+        yield test_client
+    finally:
+        test_client.close()
+        if previous_override is None:
+            app.dependency_overrides.pop(get_db, None)
+        else:
+            app.dependency_overrides[get_db] = previous_override
+        engine.dispose()
+
+
+# ── Endpoint behaviour tests ──────────────────────────────────────────────────
+
+def test_areas_returns_200(client: TestClient):
+    r = client.get("/api/areas")
+    assert r.status_code == 200
+
+
+def test_areas_root_key_is_items(client: TestClient):
+    r = client.get("/api/areas")
