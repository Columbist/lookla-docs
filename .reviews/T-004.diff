+"""
+Athens metro area presentation metadata.
+
+Keyed by the canonical address_district value stored by migration 0003.
+Provides stable slugs, localized names, and geo-classification.
+
+Rules:
+- Keys are the exact canonical values in salons.address_district.
+- Slugs are lowercase, hyphen-separated ASCII, stable across deploys.
+- Translations are explicit — no dynamic generation.
+- region/city values come from here, not from unreliable DB address_region.
+- Do not import from migration 0003 (immutable historical artifact).
+- Do not call translation or geocoding services.
+
+Coverage:
+- 46 districts with active salons (as of T-003 backfill, 2026-07-10)
+- 12 additional districts from the address normalization mapping with 0
+  active salons currently — included for future-proofing.
+"""
+
+from typing import TypedDict
+
+
