diff --git a/backend/app/routers/categories.py b/backend/app/routers/categories.py
index dc8a636..8e48557 100644
--- a/backend/app/routers/categories.py
+++ b/backend/app/routers/categories.py
@@ -4,12 +4,58 @@ from sqlalchemy import text
 from typing import Optional
 
 from app.core.database import get_db
+from app.data.area_metadata import AREA_METADATA
+from app.schemas.area import AreaItem, AreasResponse
 
 router = APIRouter(tags=["categories"])
 
 LANG_FIELD = {"el": "name_el", "en": "name_en", "ru": "name_en", "uk": "name_en"}
 
 
+@router.get("/api/areas", response_model=AreasResponse)
+def get_areas(
+    region: Optional[str] = Query(None, description="Filter by region slug (e.g. attica)"),
+    db: Session = Depends(get_db),
+):
+    """Return areas with active salon counts.
+
+    - Zero-count areas are excluded.
+    - Unknown region returns empty items, not 404.
+    - Ordered by salon_count DESC, name_en ASC.
+    """
+    rows = db.execute(text("""
+        SELECT address_district, COUNT(id) AS cnt
+        FROM salons
+        WHERE is_active = true
+          AND address_district IS NOT NULL
+          AND trim(address_district) <> ''
+        GROUP BY address_district
+    """)).fetchall()
+
+    counts: dict[str, int] = {row[0]: row[1] for row in rows}
+
+    items: list[AreaItem] = []
+    for district, meta in AREA_METADATA.items():
+        if region is not None and meta["region"] != region:
+            continue
+        count = counts.get(district, 0)
+        if count == 0:
+            continue
+        items.append(AreaItem(
+            slug=meta["slug"],
+            name_el=meta["name_el"],
+            name_en=meta["name_en"],
+            name_ru=meta["name_ru"],
+            name_uk=meta["name_uk"],
+            salon_count=count,
+            region=meta["region"],
+            city=meta["city"],
+        ))
+
+    items.sort(key=lambda x: (-x.salon_count, x.name_en))
+    return AreasResponse(items=items)
+
+
