@@ -0,0 +1,89 @@
+'use client';
+import Script from 'next/script';
+import { useEffect, useRef, useState } from 'react';
+import { usePathname, useSearchParams } from 'next/navigation';
+import {
+  getAnalyticsConsent,
+  isAnalyticsConsentFeatureEnabled,
+  CONSENT_CHANGE_EVENT,
+  type ConsentChangeEventDetail,
+} from '@/lib/consent';
+import {
+  GA4_MEASUREMENT_ID,
+  isGa4Configured,
+  initGtagIfNeeded,
+  sendPageView,
+  updateAnalyticsConsent,
+  deleteGa4Cookies,
+} from '@/lib/analytics';
+
+function currentPath(pathname: string, searchParams: URLSearchParams | null): string {
+  const query = searchParams?.toString();
+  return query ? `${pathname}?${query}` : pathname;
+}
+
+export default function GoogleAnalytics() {
+  // Once true, stays true — the <Script> tag mounts exactly once per page
+  // lifecycle and is never unmounted, so a later revoke-then-regrant cannot
+  // trigger a second script load or a second gtag('config', ...) call.
+  const [shouldLoadScript, setShouldLoadScript] = useState(false);
+  const activeRef = useRef(false);
+  const lastTrackedPath = useRef<string | null>(null);
+  const pathname = usePathname();
+  const searchParams = useSearchParams();
+
+  useEffect(() => {
+    if (!isGa4Configured() || !isAnalyticsConsentFeatureEnabled()) return;
+
+    if (getAnalyticsConsent() === 'granted') {
+      activeRef.current = true;
+      setShouldLoadScript(true);
+    }
+
+    function handleConsentChange(e: Event) {
+      const { analytics } = (e as CustomEvent<ConsentChangeEventDetail>).detail;
+      if (analytics) {
+        activeRef.current = true;
+        setShouldLoadScript(true);
+        updateAnalyticsConsent(true);
+      } else {
+        activeRef.current = false;
+        updateAnalyticsConsent(false);
+        deleteGa4Cookies();
+      }
+    }
+    window.addEventListener(CONSENT_CHANGE_EVENT, handleConsentChange);
+    return () => window.removeEventListener(CONSENT_CHANGE_EVENT, handleConsentChange);
+  }, []);
+
+  function handleScriptLoad() {
+    initGtagIfNeeded();
+    if (!activeRef.current) return;
+    const path = currentPath(pathname, searchParams);
+    lastTrackedPath.current = path;
+    sendPageView(path);
+  }
+
+  // Tracks client-side route changes only — the very first page_view is
+  // sent from handleScriptLoad, once gtag is actually ready, to avoid a
+  // race where this effect fires before the script has finished loading
+  // and the page_view is silently dropped.
+  useEffect(() => {
+    if (!activeRef.current) return;
+    if (typeof window === 'undefined' || !window.gtag) return;
+    const path = currentPath(pathname, searchParams);
+    if (path === lastTrackedPath.current) return;
+    lastTrackedPath.current = path;
+    sendPageView(path);
+  }, [pathname, searchParams]);
+
+  if (!shouldLoadScript || !isGa4Configured()) return null;
+
+  return (
+    <Script
+      src={`https://www.googletagmanager.com/gtag/js?id=${GA4_MEASUREMENT_ID}`}
+      strategy="afterInteractive"
+      onLoad={handleScriptLoad}
+    />
+  );
+}
