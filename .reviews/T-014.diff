+++ b/frontend/lib/analytics.ts
@@ -0,0 +1,90 @@
+/**
+ * T-014: GA4 infrastructure only — loading gtag.js, initializing it, sending
+ * page_view, and honoring consent. No product events here — see T-015.
+ *
+ * Deliberately does NOT use Google's "Consent Mode" default-then-update
+ * pattern, which exists for sites that load gtag.js unconditionally and
+ * rely on that mechanism to suppress it before an explicit choice is made.
+ * Here, the <script> tag itself is never rendered until consent is granted
+ * (see components/GoogleAnalytics.tsx), so there is nothing running that
+ * needs an initial state declared — the absence of the script *is* the
+ * denial. The consent-update call further below is only for revoking (or
+ * resuming) after the script has already loaded once.
+ */
+
+export const GA4_MEASUREMENT_ID = process.env.NEXT_PUBLIC_GA4_ID || '';
+
+declare global {
+  interface Window {
+    dataLayer?: unknown[];
+    gtag?: (...args: unknown[]) => void;
+  }
+}
+
+let initialized = false;
+
+/** True only once a real Measurement ID is configured — stays false (and everything else stays inert) until T-013 provisions one. */
+export function isGa4Configured(): boolean {
+  return GA4_MEASUREMENT_ID.length > 0;
+}
+
+/**
+ * Sets up window.dataLayer/window.gtag and sends the config call.
+ * Idempotent — safe to call more than once; only runs the setup the first time.
+ * `send_page_view: false` because page_view is sent explicitly (see sendPageView),
+ * both for the initial load and for client-side route changes, which GA4's
+ * automatic pageview measurement does not see in a Next.js App Router SPA.
+ */
+export function initGtagIfNeeded(): void {
+  if (initialized) return;
+  if (typeof window === 'undefined') return;
+  window.dataLayer = window.dataLayer || [];
+  window.gtag = function gtag(...args: unknown[]) {
+    window.dataLayer!.push(args);
+  };
+  window.gtag('js', new Date());
+  window.gtag('config', GA4_MEASUREMENT_ID, { send_page_view: false });
+  initialized = true;
+}
+
+/** Sends a single page_view for the given path. No-op if gtag isn't loaded yet. */
+export function sendPageView(pagePath: string): void {
+  if (typeof window === 'undefined' || !window.gtag) return;
+  window.gtag('event', 'page_view', { page_path: pagePath });
+}
+
+/** Tells GA4 to stop (or resume) sending data. Only meaningful once the script has already loaded once. */
+export function updateAnalyticsConsent(granted: boolean): void {
+  if (typeof window === 'undefined' || !window.gtag) return;
+  window.gtag('consent', 'update', { analytics_storage: granted ? 'granted' : 'denied' });
+}
+
+/**
+ * Best-effort deletion of GA4's own cookies (_ga, _ga_<container-suffix>) on
+ * the current host and, where the site is served from a subdomain, the
+ * registrable parent domain too. GA4 does not delete these itself when
+ * consent is revoked via gtag('consent', 'update', ...) — that stops future
+ * writes, it doesn't clear what's already there.
+ */
+export function deleteGa4Cookies(): void {
+  if (typeof document === 'undefined') return;
+  const names = document.cookie
+    .split(';')
+    .map(c => c.trim().split('=')[0])
+    .filter(name => name === '_ga' || name.startsWith('_ga_'));
+
+  for (const name of names) {
+    document.cookie = `${name}=; Path=/; Max-Age=0; SameSite=Lax`;
+    const host = window.location.hostname;
+    const parts = host.split('.');
+    if (parts.length > 2) {
+      const parentDomain = '.' + parts.slice(-2).join('.');
+      document.cookie = `${name}=; Path=/; Domain=${parentDomain}; Max-Age=0; SameSite=Lax`;
+    }
+  }
+}
+
+/** Test-only: resets the module-level init flag between test cases. */
+export function _resetForTests(): void {
+  initialized = false;
+}
