+++ b/frontend/lib/apiInternalUrl.test.ts
@@ -0,0 +1,47 @@
+import { test, describe } from 'node:test';
+import assert from 'node:assert/strict';
+import { resolveApiInternalUrl } from './apiInternalUrl.mjs';
+
+describe('resolveApiInternalUrl', () => {
+  test('defaults to Docker service DNS, not loopback', () => {
+    assert.equal(resolveApiInternalUrl({}), 'http://api:8001/api');
+  });
+
+  test('never returns a destination containing 127.0.0.1 or localhost by default', () => {
+    const url = resolveApiInternalUrl({});
+    assert.ok(!url.includes('127.0.0.1'), `default must not use loopback IP, got "${url}"`);
+    assert.ok(!url.includes('localhost'), `default must not use localhost, got "${url}"`);
+  });
+
+  test('respects a custom API_INTERNAL_URL', () => {
+    assert.equal(
+      resolveApiInternalUrl({ API_INTERNAL_URL: 'http://custom-host:9000/api' }),
+      'http://custom-host:9000/api',
+    );
+  });
+
+  test('strips a trailing slash so the rewrite does not produce a double slash', () => {
+    const url = resolveApiInternalUrl({ API_INTERNAL_URL: 'http://api:8001/api/' });
+    assert.equal(url, 'http://api:8001/api');
+    assert.equal(`${url}/:path*`, 'http://api:8001/api/:path*');
+  });
+
+  test('strips multiple trailing slashes', () => {
+    assert.equal(resolveApiInternalUrl({ API_INTERNAL_URL: 'http://api:8001/api///' }), 'http://api:8001/api');
+  });
+});
+
+describe('next.config.mjs rewrite (integration)', () => {
+  test('rewrite source is /api/:path* and destination uses the resolved internal URL', async () => {
+    const config = (await import('../next.config.mjs')).default;
+    const rewrites = await config.rewrites();
+    assert.equal(rewrites.length, 1);
+    assert.equal(rewrites[0].source, '/api/:path*');
+    assert.ok(
+      rewrites[0].destination.startsWith(resolveApiInternalUrl()),
+      `destination "${rewrites[0].destination}" should start with resolved API_INTERNAL_URL`,
+    );
+    assert.ok(!rewrites[0].destination.includes('127.0.0.1'));
+    assert.ok(!rewrites[0].destination.includes('localhost'));
+  });
+});
