diff --git a/frontend/lib/apiInternalUrl.mjs b/frontend/lib/apiInternalUrl.mjs
new file mode 100644
index 0000000..9dd3f10
--- /dev/null
+++ b/frontend/lib/apiInternalUrl.mjs
@@ -0,0 +1,8 @@
+// Shared by next.config.mjs (rewrite destination) and lib/api.ts (SSR fetch
+// base). Must resolve to Docker service DNS, never loopback — 127.0.0.1 or
+// localhost inside the `web` container refers to the web container itself,
+// not the `api` service.
+export function resolveApiInternalUrl(env = process.env) {
+  const raw = env.API_INTERNAL_URL || 'http://api:8001/api';
+  return raw.replace(/\/+$/, '');
+}
