+import { test, describe } from 'node:test';
+import assert from 'node:assert/strict';
+import fs from 'node:fs';
+import path from 'node:path';
+import { fileURLToPath } from 'node:url';
+import {
+  normalizePhoneForWhatsApp,
+  normalizePhoneForCall,
+  normalizeWebsiteUrl,
+  resolveContactActions,
+  hasAnyContactAction,
+} from './contactActions';
+
+const here = path.dirname(fileURLToPath(import.meta.url));
+const frontendRoot = path.join(here, '..');
+
+describe('normalizePhoneForWhatsApp', () => {
+  test('strips spaces, +, parentheses, dashes — digits only', () => {
+    assert.equal(normalizePhoneForWhatsApp('+30 210 123 4567'), '302101234567');
+    assert.equal(normalizePhoneForWhatsApp('+30 (694) 123-4567'), '306941234567');
+  });
+
+  test('returns null for null/undefined input', () => {
+    assert.equal(normalizePhoneForWhatsApp(null), null);
+    assert.equal(normalizePhoneForWhatsApp(undefined), null);
+  });
+
+  test('returns null when no digits remain', () => {
+    assert.equal(normalizePhoneForWhatsApp('---'), null);
+    assert.equal(normalizePhoneForWhatsApp('   '), null);
+  });
+
+  test('does not invent a Greek country code for a local number', () => {
+    assert.equal(normalizePhoneForWhatsApp('210 123 4567'), '2101234567');
+  });
+});
+
+describe('normalizePhoneForCall', () => {
+  test('keeps a leading + for international numbers, strips formatting', () => {
+    assert.equal(normalizePhoneForCall('+30 210 123 4567'), '+302101234567');
+    assert.equal(normalizePhoneForCall('+30 (694) 123-4567'), '+306941234567');
+  });
+
+  test('does not add a + or invent a country code for a local number', () => {
+    assert.equal(normalizePhoneForCall('210 123 4567'), '2101234567');
+  });
+
+  test('returns null for empty/unusable input', () => {
+    assert.equal(normalizePhoneForCall(null), null);
+    assert.equal(normalizePhoneForCall('---'), null);
+  });
+});
+
+describe('normalizeWebsiteUrl', () => {
+  test('adds https:// to a bare hostname', () => {
+    assert.equal(normalizeWebsiteUrl('example.com'), 'https://example.com');
+    assert.equal(normalizeWebsiteUrl('www.example.com'), 'https://www.example.com');
+  });
+
+  test('preserves an existing https:// URL unchanged', () => {
+    assert.equal(normalizeWebsiteUrl('https://example.com'), 'https://example.com');
+  });
+
+  test('preserves an existing http:// URL unchanged', () => {
+    assert.equal(normalizeWebsiteUrl('http://example.com'), 'http://example.com');
+  });
+
+  test('returns null for empty/whitespace-only values', () => {
+    assert.equal(normalizeWebsiteUrl(''), null);
+    assert.equal(normalizeWebsiteUrl('   '), null);
+    assert.equal(normalizeWebsiteUrl(null), null);
+    assert.equal(normalizeWebsiteUrl(undefined), null);
+  });
+
+  test('rejects javascript:, data:, and file: schemes', () => {
+    assert.equal(normalizeWebsiteUrl('javascript:alert(1)'), null);
+    assert.equal(normalizeWebsiteUrl('data:text/html,<script>alert(1)</script>'), null);
+    assert.equal(normalizeWebsiteUrl('file:///etc/passwd'), null);
+  });
+
+  test('rejects other unexpected schemes rather than guessing intent', () => {
+    assert.equal(normalizeWebsiteUrl('ftp://example.com'), null);
+  });
+
+  test('never throws on malformed input', () => {
+    assert.doesNotThrow(() => normalizeWebsiteUrl('http://'));
+    assert.doesNotThrow(() => normalizeWebsiteUrl(':::'));
+  });
+});
+
+describe('T-010 CTA contract: exactly Call, WhatsApp, Website — no Viber, no booking', () => {
+  test('zero available actions when phone and website are both absent', () => {
+    const actions = resolveContactActions(null, null);
+    assert.equal(actions.callHref, null);
+    assert.equal(actions.whatsappHref, null);
+    assert.equal(actions.websiteHref, null);
+    assert.equal(hasAnyContactAction(actions), false, 'no actions should activate the empty state');
+  });
+
+  test('one available action (phone only) does not activate the empty state', () => {
+    const actions = resolveContactActions('+30 210 123 4567', null);
+    assert.ok(actions.callHref);
+    assert.ok(actions.whatsappHref);
+    assert.equal(actions.websiteHref, null);
+    assert.equal(hasAnyContactAction(actions), true);
+  });
+
+  test('one available action (website only) does not activate the empty state', () => {
+    const actions = resolveContactActions(null, 'example.com');
+    assert.equal(actions.callHref, null);
+    assert.equal(actions.whatsappHref, null);
+    assert.ok(actions.websiteHref);
+    assert.equal(hasAnyContactAction(actions), true);
+  });
+
+  test('all three actions render when phone and website are both present', () => {
+    const actions = resolveContactActions('+30 210 123 4567', 'example.com');
+    assert.ok(actions.callHref);
+    assert.ok(actions.whatsappHref);
+    assert.ok(actions.websiteHref);
+  });
+
+  test('resolveContactActions exposes exactly 3 action fields — no fourth (Viber) field', () => {
+    const actions = resolveContactActions('+30 210 123 4567', 'example.com');
+    assert.deepEqual(Object.keys(actions).sort(), ['callHref', 'whatsappHref', 'websiteHref'].sort());
+  });
+
+  test('ContactButtons.tsx source has no Viber, booking, or auth-check code', () => {
+    const source = fs.readFileSync(path.join(frontendRoot, 'components', 'ContactButtons.tsx'), 'utf-8');
+    for (const banned of ['viber', 'Viber', "t('book')", "t('request')", 'useAuth', 'requireAuth', 'isLoggedIn']) {
+      assert.ok(!source.includes(banned), `ContactButtons.tsx must not contain "${banned}"`);
+    }
+  });
+
+  test('ContactButtons.tsx contains no authentication dependency (no fetch("/api/auth") or credentials check)', () => {
+    const source = fs.readFileSync(path.join(frontendRoot, 'components', 'ContactButtons.tsx'), 'utf-8');
+    assert.ok(!source.includes('/api/auth'), 'ContactButtons must not gate on auth');
+    assert.ok(!source.includes('credentials'), 'ContactButtons must not gate on credentials/session');
+  });
+
+  test('WhatsApp and Website links use target=_blank + noopener noreferrer', () => {
+    const source = fs.readFileSync(path.join(frontendRoot, 'components', 'ContactButtons.tsx'), 'utf-8');
+    const occurrences = (source.match(/rel="noopener noreferrer"/g) || []).length;
+    assert.equal(occurrences, 2, 'expected exactly 2 external links (WhatsApp, Website) with noopener noreferrer');
+  });
+});
+
