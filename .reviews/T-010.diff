+'use client';
+import { useTranslations } from 'next-intl';
+import ReportButton from '@/components/ReportButton';
+import { resolveContactActions, hasAnyContactAction } from '@/lib/contactActions';
+
+interface ContactButtonsProps {
+  phone: string | null;
+  websiteUrl: string | null;
+  salonName: string;
+  salonId: number;
+  locale: string;
+}
+
+const BUTTON_CLASS = 'flex items-center justify-center gap-2 px-4 py-3.5 rounded-xl text-base font-semibold min-h-[48px]';
+
+export default function ContactButtons({ phone, websiteUrl, salonName, salonId, locale }: ContactButtonsProps) {
+  const t = useTranslations('salon');
+
+  const actions = resolveContactActions(phone, websiteUrl);
+
+  if (!hasAnyContactAction(actions)) {
+    return (
+      <div className="text-center py-2">
+        <p className="text-sm text-gray-500 mb-2">{t('contactInfoUnavailable')}</p>
+        <ReportButton salonId={salonId} locale={locale} label={t('report')} />
+      </div>
+    );
+  }
+
+  return (
+    <div className="grid grid-cols-2 gap-2">
+      {actions.callHref && (
+        <a
+          href={actions.callHref}
+          aria-label={`${t('callSalon')} ${salonName}`}
+          className={`${BUTTON_CLASS} bg-green-50 text-green-700 hover:bg-green-100`}
+        >
+          📞 {t('callSalon')}
+          {phone && <span className="hidden sm:inline text-green-600 font-normal">· {phone}</span>}
+        </a>
+      )}
+      {actions.whatsappHref && (
+        <a
+          href={actions.whatsappHref}
+          target="_blank"
+          rel="noopener noreferrer"
+          aria-label={`${t('messageWhatsApp')} ${salonName}`}
+          className={`${BUTTON_CLASS} bg-emerald-50 text-emerald-700 hover:bg-emerald-100`}
+        >
+          💬 {t('messageWhatsApp')}
+        </a>
+      )}
+      {actions.websiteHref && (
+        <a
+          href={actions.websiteHref}
+          target="_blank"
+          rel="noopener noreferrer"
+          aria-label={`${t('visitWebsite')} ${salonName}`}
+          className={`${BUTTON_CLASS} bg-blue-50 text-blue-700 hover:bg-blue-100`}
+        >
+          🌐 {t('visitWebsite')}
+        </a>
+      )}
+    </div>
+  );
+}
