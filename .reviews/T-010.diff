+      for (const key of ['callSalon', 'messageWhatsApp', 'visitWebsite', 'contactInfoUnavailable']) {
+        assert.ok(key in messages.salon, `${locale}.json salon.${key} missing`);
+        assert.ok(messages.salon[key].length > 0, `${locale}.json salon.${key} is empty`);
+      }
+      assert.ok(!('viber' in messages.salon), `${locale}.json salon.viber should have been removed`);
+    });
+  }
+});
diff --git a/frontend/lib/contactActions.ts b/frontend/lib/contactActions.ts
new file mode 100644
index 0000000..3df42ba
--- /dev/null
+++ b/frontend/lib/contactActions.ts
@@ -0,0 +1,53 @@
+const UNSAFE_SCHEME = /^(javascript|data|file):/i;
+const HTTP_SCHEME = /^https?:\/\//i;
+const ANY_SCHEME = /^[a-z][a-z0-9+.-]*:\/\//i;
+
+/** Digits-only phone for wa.me links. Never invents a country code. */
+export function normalizePhoneForWhatsApp(phone: string | null | undefined): string | null {
+  if (!phone) return null;
+  const digits = phone.trim().replace(/\D/g, '');
+  return digits.length > 0 ? digits : null;
+}
+
+/** tel: href — keeps a leading "+" for international format, strips formatting chars. Never invents a country code. */
+export function normalizePhoneForCall(phone: string | null | undefined): string | null {
+  if (!phone) return null;
+  const trimmed = phone.trim();
+  const hasPlus = trimmed.startsWith('+');
+  const digits = trimmed.replace(/\D/g, '');
+  if (digits.length === 0) return null;
+  return hasPlus ? `+${digits}` : digits;
+}
+
+/** Adds https:// to a bare hostname, preserves http(s):// as-is, rejects unsafe/unexpected schemes. */
+export function normalizeWebsiteUrl(value: string | null | undefined): string | null {
+  if (!value) return null;
+  const trimmed = value.trim();
+  if (trimmed.length === 0) return null;
+  if (UNSAFE_SCHEME.test(trimmed)) return null;
+  if (HTTP_SCHEME.test(trimmed)) return trimmed;
+  if (ANY_SCHEME.test(trimmed)) return null;
+  return `https://${trimmed}`;
+}
+
+/** The exactly-3-action T-010 contract. No Viber, no booking, no fourth action. */
+export interface ContactActions {
+  callHref: string | null;
+  whatsappHref: string | null;
+  websiteHref: string | null;
+}
+
+export function resolveContactActions(phone: string | null | undefined, website: string | null | undefined): ContactActions {
+  const callDigits = normalizePhoneForCall(phone);
+  const waDigits = normalizePhoneForWhatsApp(phone);
+  const site = normalizeWebsiteUrl(website);
+  return {
+    callHref: callDigits ? `tel:${callDigits}` : null,
+    whatsappHref: waDigits ? `https://wa.me/${waDigits}` : null,
+    websiteHref: site,
+  };
+}
+
+export function hasAnyContactAction(actions: ContactActions): boolean {
+  return Boolean(actions.callHref || actions.whatsappHref || actions.websiteHref);
+}
