diff --git a/frontend/lib/areaFilter.ts b/frontend/lib/areaFilter.ts
new file mode 100644
index 0000000..82f825f
--- /dev/null
+++ b/frontend/lib/areaFilter.ts
@@ -0,0 +1,41 @@
+// Pure helpers for the Search page Area filter (T-007). Kept dependency-free
+// (no React/DOM) so they can run under node:test without a browser/JSDOM.
+import type { Locale } from '@/i18n/request';
+import type { AreaItem } from '@/lib/api';
+
+export function getAreaName(area: AreaItem, locale: Locale): string {
+  switch (locale) {
+    case 'el':
+      return area.name_el;
+    case 'ru':
+      return area.name_ru;
+    case 'uk':
+      return area.name_uk;
+    default:
+      return area.name_en;
+  }
+}
+
+export function findAreaBySlug(areas: AreaItem[], slug: string): AreaItem | undefined {
+  return areas.find(a => a.slug === slug);
+}
+
+/**
+ * Applies the Area-select onChange semantics to a URLSearchParams instance:
+ * selecting a slug sets `area` and drops the legacy `city` param (T-005:
+ * area takes precedence server-side, but the UI only ever has one active
+ * location control at a time); clearing the selection just drops `area`.
+ * Always resets `page` since the result set changes. Returns a new
+ * URLSearchParams — does not mutate the input.
+ */
+export function buildAreaUrlParams(current: URLSearchParams, slug: string): URLSearchParams {
+  const params = new URLSearchParams(current);
+  if (slug) {
+    params.set('area', slug);
+    params.delete('city');
+  } else {
+    params.delete('area');
+  }
+  params.delete('page');
+  return params;
+}
