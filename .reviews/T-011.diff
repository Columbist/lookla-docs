diff --git a/frontend/lib/verificationLabel.test.ts b/frontend/lib/verificationLabel.test.ts
new file mode 100644
index 0000000..f20e266
--- /dev/null
+++ b/frontend/lib/verificationLabel.test.ts
@@ -0,0 +1,74 @@
+import { test, describe } from 'node:test';
+import assert from 'node:assert/strict';
+import fs from 'node:fs';
+import path from 'node:path';
+import { fileURLToPath } from 'node:url';
+import { getVerificationLabelKey } from './verificationLabel';
+
+const here = path.dirname(fileURLToPath(import.meta.url));
+const frontendRoot = path.join(here, '..');
+
+describe('getVerificationLabelKey — T-011 (DEC-014)', () => {
+  test('returns "ownerVerified" when is_owner_claimed is true', () => {
+    assert.equal(getVerificationLabelKey(true), 'ownerVerified');
+  });
+
+  test('returns "infoReviewed" when is_owner_claimed is false', () => {
+    assert.equal(getVerificationLabelKey(false), 'infoReviewed');
+  });
+
+  test('returns "infoReviewed" when is_owner_claimed is undefined (field absent)', () => {
+    assert.equal(getVerificationLabelKey(undefined), 'infoReviewed');
+  });
+});
+
+describe('T-011: locale files define infoReviewed/ownerVerified, no leftover "verified" key', () => {
+  const locales = ['el', 'en', 'ru', 'uk'] as const;
+  for (const locale of locales) {
+    test(`${locale}.json salon.infoReviewed / salon.ownerVerified present and non-empty`, () => {
+      const messages = JSON.parse(fs.readFileSync(path.join(frontendRoot, 'messages', `${locale}.json`), 'utf-8'));
+      for (const key of ['infoReviewed', 'ownerVerified']) {
+        assert.ok(key in messages.salon, `${locale}.json salon.${key} missing`);
+        assert.ok(messages.salon[key].length > 0, `${locale}.json salon.${key} is empty`);
+      }
+    });
+
+    test(`${locale}.json salon.verified was removed (superseded by DEC-014 text labels)`, () => {
+      const messages = JSON.parse(fs.readFileSync(path.join(frontendRoot, 'messages', `${locale}.json`), 'utf-8'));
+      assert.ok(!('verified' in messages.salon), `${locale}.json salon.verified should have been removed`);
+    });
+  }
+});
+
+describe('T-011: DEC-014 — no bare checkmark icon on verification labels', () => {
+  test('SalonDetailClient.tsx does not render a ✓ icon next to the verification label', () => {
+    const source = fs.readFileSync(
+      path.join(frontendRoot, 'app', '[locale]', 'salons', '[slug]', 'SalonDetailClient.tsx'),
+      'utf-8',
+    );
+    assert.ok(!source.includes('✓'), 'SalonDetailClient.tsx must not contain a ✓ icon (DEC-014: text only)');
+  });
+
+  test('SalonCard.tsx does not render a ✓ icon next to the verification label', () => {
+    const source = fs.readFileSync(path.join(frontendRoot, 'components', 'SalonCard.tsx'), 'utf-8');
+    assert.ok(!source.includes('✓'), 'SalonCard.tsx must not contain a ✓ icon (DEC-014: text only)');
+  });
+});
+
+describe('T-011 non-regression: T-010 CTA contract untouched by verification-label change', () => {
+  test('ContactButtons.tsx still has no Viber/booking/auth-check code', () => {
+    const source = fs.readFileSync(path.join(frontendRoot, 'components', 'ContactButtons.tsx'), 'utf-8');
+    for (const banned of ['viber', 'Viber', "t('book')", "t('request')", 'useAuth', 'requireAuth', 'isLoggedIn']) {
+      assert.ok(!source.includes(banned), `ContactButtons.tsx must not contain "${banned}"`);
+    }
+  });
+});
+
+describe('T-011 non-regression: T-012 review-source label untouched by verification-label change', () => {
+  test('shouldShowReviewSourceLabel is unchanged (still section-level, not per-review)', async () => {
+    const { shouldShowReviewSourceLabel } = await import('./reviewsSection');
+    assert.equal(shouldShowReviewSourceLabel(true, 0), false, 'while loading, never show');
+    assert.equal(shouldShowReviewSourceLabel(false, 0), false, 'zero reviews, never show');
+    assert.equal(shouldShowReviewSourceLabel(false, 1), true, 'loaded with reviews, show');
+  });
+});
diff --git a/frontend/lib/verificationLabel.ts b/frontend/lib/verificationLabel.ts
new file mode 100644
index 0000000..389b816
--- /dev/null
+++ b/frontend/lib/verificationLabel.ts
@@ -0,0 +1,12 @@
+/**
+ * T-011 (DEC-014): text-only verification label, sole source of truth is
+ * `is_owner_claimed`. The existing `is_verified` gate (already used to
+ * decide whether any badge renders at all) is left untouched by callers —
+ * this only picks which of the two approved strings to show once that gate
+ * has passed.
+ */
+export type VerificationLabelKey = 'ownerVerified' | 'infoReviewed';
+
+export function getVerificationLabelKey(isOwnerClaimed: boolean | undefined): VerificationLabelKey {
+  return isOwnerClaimed === true ? 'ownerVerified' : 'infoReviewed';
+}
