@@ -0,0 +1,32 @@
+'use client';
+import { useEffect, useRef } from 'react';
+import type { AsyncStatus } from '@/lib/asyncState';
+
+/**
+ * T-042: moves keyboard focus back into a region after recovering from
+ * 'error' (e.g. via Retry). Without this, activating Retry unmounts the
+ * button the user just clicked the instant status leaves 'error' — for a
+ * keyboard or screen-reader user, focus would otherwise silently drop back
+ * to the document body with no indication anything happened.
+ *
+ * Attach the returned ref to the region's own root element (it must be
+ * focusable — give it `tabIndex={-1}`). Shared across every AsyncSection
+ * call site so the recovery-timing logic exists in exactly one place,
+ * even though the DOM wrapper it attaches to is necessarily per-call-site
+ * (some loading/empty/error content is itself a set of CSS Grid items —
+ * see search/page.tsx — where an extra shared wrapper div would break the
+ * grid; AsyncSection itself stays wrapper-free for exactly this reason).
+ */
+export function useFocusOnStatusRecovery<T extends HTMLElement>(status: AsyncStatus) {
+  const ref = useRef<T>(null);
+  const prevStatus = useRef<AsyncStatus | null>(null);
+
+  useEffect(() => {
+    if (prevStatus.current === 'error' && status !== 'error') {
+      ref.current?.focus();
+    }
+    prevStatus.current = status;
+  }, [status]);
+
+  return ref;
+}
