+  test('empty only applies once not loading and not errored', () => {
+    assert.equal(deriveAsyncStatus(false, false, true), 'empty');
+  });
+
+  test('success is the only remaining case', () => {
+    assert.equal(deriveAsyncStatus(false, false, false), 'success');
+  });
+});
