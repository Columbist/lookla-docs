@@ -0,0 +1,24 @@
+import type { ReactNode } from 'react';
+import type { AsyncStatus } from '@/lib/asyncState';
+
+interface AsyncSectionProps {
+  status: AsyncStatus;
+  loading: ReactNode;
+  empty: ReactNode;
+  error: ReactNode;
+  children: ReactNode;
+}
+
+/**
+ * T-042: the single place that turns an AsyncStatus into UI. Intentionally
+ * unstyled/unopinionated — each call site supplies its own loading skeleton,
+ * empty-state message, and error message (typically with a retry action),
+ * since Services/Reviews cards and the search results grid have different
+ * containers. What's shared is the state machine, not the markup.
+ */
+export default function AsyncSection({ status, loading, empty, error, children }: AsyncSectionProps) {
+  if (status === 'loading') return <>{loading}</>;
+  if (status === 'error') return <>{error}</>;
+  if (status === 'empty') return <>{empty}</>;
+  return <>{children}</>;
+}
