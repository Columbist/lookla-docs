new file mode 100644
index 0000000..cd93564
--- /dev/null
+++ b/frontend/lib/asyncState.ts
@@ -0,0 +1,22 @@
+/**
+ * T-042: the one status shape every async section in the product should
+ * use — loading vs. genuinely-empty vs. failed-to-load vs. has-content.
+ * Kept dependency-free (no React) so it's directly unit-testable and reusable
+ * anywhere a fetch result needs to become UI: search results, Services,
+ * Reviews, and future owner-dashboard sections.
+ */
+export type AsyncStatus = 'loading' | 'empty' | 'error' | 'success';
+
+/**
+ * Precedence: loading wins over everything (a stale error/empty from a
+ * previous attempt must not flash while a retry is in flight); error wins
+ * over empty (a failed fetch is not the same claim as "there is genuinely
+ * nothing here"); empty only applies once we know loading is done and
+ * nothing went wrong.
+ */
+export function deriveAsyncStatus(loading: boolean, error: boolean, isEmpty: boolean): AsyncStatus {
+  if (loading) return 'loading';
+  if (error) return 'error';
+  if (isEmpty) return 'empty';
+  return 'success';
+}
