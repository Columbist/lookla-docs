+describe('T-042: deriveAsyncStatus', () => {
+  test('loading wins regardless of error/empty flags', () => {
+    assert.equal(deriveAsyncStatus(true, false, false), 'loading');
+    assert.equal(deriveAsyncStatus(true, true, false), 'loading');
