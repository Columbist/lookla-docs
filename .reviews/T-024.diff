@@ -0,0 +1,283 @@
+"""
+T-024: `is_owner_claimed` on GET /api/salons and GET /api/salons/{id_or_slug}.
+
+Uses FastAPI TestClient with SQLite in-memory DB via dependency override.
+No connection to production. The EXISTS-based query is plain, portable SQL
+(no Postgres-only syntax) and runs unmodified against SQLite here — the
+same query that runs in production.
+"""
+import pytest
+from fastapi.testclient import TestClient
+from sqlalchemy import create_engine, event
+from sqlalchemy.orm import sessionmaker
+from sqlalchemy.pool import StaticPool
+
+from app.main import app
+from app.core.database import get_db, Base
+from app.models.salon import Salon, SalonOwner
+from app.models.user import User
+import app.routers.salons as salons_module
+
+
+def _build_test_engine():
+    engine = create_engine(
+        "sqlite:///:memory:",
+        connect_args={"check_same_thread": False},
+        poolclass=StaticPool,
+    )
+    Base.metadata.create_all(engine)
+    return engine
+
+
+SEED_SALONS = [
+    dict(id=1, name="Claimed Salon", slug="claimed-salon", address_city="Glyfada",
+         is_active=True, rating_google=4.7, rating_count=10),
+    dict(id=2, name="Unclaimed Salon", slug="unclaimed-salon", address_city="Glyfada",
+         is_active=True, rating_google=4.5, rating_count=20),
+    dict(id=3, name="Double Claimed Salon", slug="double-claimed-salon", address_city="Glyfada",
+         is_active=True, rating_google=4.9, rating_count=5),
+    dict(id=4, name="Inactive Claimed Salon", slug="inactive-claimed-salon", address_city="Glyfada",
+         is_active=False, rating_google=4.0, rating_count=3),
+]
+
+
+@pytest.fixture(scope="module")
+def client():
+    engine = _build_test_engine()
+    test_session_local = sessionmaker(autocommit=False, autoflush=False, bind=engine)
+
+    session = test_session_local()
+    for row in SEED_SALONS:
+        session.add(Salon(**row))
+    session.add(User(id=1, email="owner1@example.com"))
+    session.add(User(id=2, email="owner2@example.com"))
+    session.commit()
+
+    # Salon 1: claimed by one owner. Salon 3: two owner rows for the same
+    # salon (the DB schema allows this — no unique constraint on salon_id
+    # alone, only a composite PK on (user_id, salon_id)) — must still
+    # resolve to a single `true`, not duplicate the salon in list results.
+    session.add(SalonOwner(user_id=1, salon_id=1))
+    session.add(SalonOwner(user_id=1, salon_id=3))
+    session.add(SalonOwner(user_id=2, salon_id=3))
+    session.add(SalonOwner(user_id=1, salon_id=4))  # inactive salon, claimed
+    session.commit()
+    session.close()
+
+    def override_get_db():
+        db = test_session_local()
+        try:
+            yield db
+        finally:
+            db.close()
+
+    previous_override = app.dependency_overrides.get(get_db)
+    app.dependency_overrides[get_db] = override_get_db
+
+    # Postgres-only batch helpers (unrelated to T-024) — same stubbing
+    # pattern as test_salons_endpoint.py.
+    original_photos = salons_module._batch_primary_photos
+    original_prices = salons_module._batch_min_prices
+    original_open = salons_module._batch_open_now
+    salons_module._batch_primary_photos = lambda salon_ids, db: {}
+    salons_module._batch_min_prices = lambda salon_ids, db, name_keywords=None: {}
+    salons_module._batch_open_now = lambda salon_ids, db: {}
+
+    test_client = TestClient(app)
+    test_client.engine = engine
+    try:
+        yield test_client
+    finally:
+        test_client.close()
+        salons_module._batch_primary_photos = original_photos
+        salons_module._batch_min_prices = original_prices
+        salons_module._batch_open_now = original_open
+        if previous_override is None:
+            app.dependency_overrides.pop(get_db, None)
+        else:
+            app.dependency_overrides[get_db] = previous_override
+        engine.dispose()
+
+
+def _query_count(client: TestClient, url: str) -> int:
+    return len(_captured_statements(client, url))
+
+
+def _captured_statements(client: TestClient, url: str) -> list[str]:
+    statements = []
+
+    def _log(conn, cursor, statement, parameters, context, executemany):
+        statements.append(statement)
+
+    event.listen(client.engine, "before_cursor_execute", _log)
+    try:
+        resp = client.get(url)
+    finally:
+        event.remove(client.engine, "before_cursor_execute", _log)
+    assert resp.status_code == 200
+    return statements
+
+
+def _item_by_name(items, name):
+    return next(i for i in items if i["name"] == name)
+
+
+# ── Schema / OpenAPI ───────────────────────────────────────────────────────────
+
+def test_schema_field_is_owner_claimed_present_in_list_schema():
+    from app.schemas.salon import SalonListItem
+    assert "is_owner_claimed" in SalonListItem.model_fields
+
+
+def test_schema_field_is_owner_claimed_present_in_detail_schema():
+    from app.schemas.salon import SalonDetail
+    assert "is_owner_claimed" in SalonDetail.model_fields
+
+
+def test_openapi_is_owner_claimed_required_boolean_in_list_and_detail():
+    spec = app.openapi()
+    schemas = spec["components"]["schemas"]
+    for name in ("SalonListItem", "SalonDetail"):
+        props = schemas[name]["properties"]
+        required = schemas[name].get("required", [])
+        assert "is_owner_claimed" in props, f"{name} missing is_owner_claimed"
+        assert props["is_owner_claimed"]["type"] == "boolean"
+        assert "is_owner_claimed" in required, f"{name}.is_owner_claimed must be required"
+
+
+def test_openapi_map_schema_unchanged():
+    spec = app.openapi()
+    props = spec["components"]["schemas"]["SalonMapItem"]["properties"]
+    assert "is_owner_claimed" not in props
+    assert len(props) == 10  # T-038's confirmed ten-field contract
+
+
+# ── List endpoint ──────────────────────────────────────────────────────────────
+
+def test_list_claimed_salon_returns_true(client):
+    resp = client.get("/api/salons")
+    items = resp.json()["items"]
+    assert _item_by_name(items, "Claimed Salon")["is_owner_claimed"] is True
+
+
+def test_list_unclaimed_salon_returns_false(client):
+    resp = client.get("/api/salons")
+    items = resp.json()["items"]
+    assert _item_by_name(items, "Unclaimed Salon")["is_owner_claimed"] is False
+
+
+def test_list_duplicate_ownership_rows_do_not_duplicate_salon(client):
+    resp = client.get("/api/salons")
+    items = resp.json()["items"]
+    matches = [i for i in items if i["name"] == "Double Claimed Salon"]
+    assert len(matches) == 1
+
+
+def test_list_duplicate_ownership_rows_still_true(client):
+    resp = client.get("/api/salons")
+    items = resp.json()["items"]
+    assert _item_by_name(items, "Double Claimed Salon")["is_owner_claimed"] is True
+
+
+def test_list_inactive_claimed_salon_excluded(client):
+    resp = client.get("/api/salons")
+    data = resp.json()
+    names = {i["name"] for i in data["items"]}
+    assert "Inactive Claimed Salon" not in names
+    assert data["total"] == 3
+
+
+def test_list_no_n_plus_1_ownership_queries(client):
+    # Query count must be identical whether or not any salon is claimed —
+    # the EXISTS is embedded in the same list query, not a per-row lookup.
+    assert _query_count(client, "/api/salons") == _query_count(client, "/api/salons")
+
+
+def test_list_query_count_is_two(client):
+    # One count() query + one main list query (with the EXISTS column
+    # embedded) — no separate ownership round-trip. Matches the batch-helper
+    # stubs returning {} without issuing queries.
+    n = _query_count(client, "/api/salons")
+    assert n == 2, f"expected exactly 2 SQL statements (count + list), got {n}"
+
+
+def test_list_ordering_unchanged(client):
+    # default sort: rating_google DESC, rating_count DESC — unaffected by
+    # ownership status. Double Claimed (4.9) > Claimed (4.7) > Unclaimed (4.5)
+    resp = client.get("/api/salons")
+    names = [i["name"] for i in resp.json()["items"]]
+    assert names == ["Double Claimed Salon", "Claimed Salon", "Unclaimed Salon"]
+
+
+# ── Detail endpoint ────────────────────────────────────────────────────────────
+
+def test_detail_claimed_salon_by_id_returns_true(client):
+    resp = client.get("/api/salons/1")
+    assert resp.status_code == 200
+    assert resp.json()["is_owner_claimed"] is True
+
+
+def test_detail_claimed_salon_by_slug_returns_true(client):
+    resp = client.get("/api/salons/claimed-salon")
+    assert resp.status_code == 200
+    assert resp.json()["is_owner_claimed"] is True
+
+
+def test_detail_unclaimed_salon_by_id_returns_false(client):
+    resp = client.get("/api/salons/2")
+    assert resp.json()["is_owner_claimed"] is False
+
+
+def test_detail_unclaimed_salon_by_slug_returns_false(client):
+    resp = client.get("/api/salons/unclaimed-salon")
+    assert resp.json()["is_owner_claimed"] is False
+
+
+def test_detail_double_claimed_salon_returns_true_not_an_error(client):
+    resp = client.get("/api/salons/double-claimed-salon")
+    assert resp.status_code == 200
+    assert resp.json()["is_owner_claimed"] is True
+
+
+def test_detail_inactive_salon_still_404(client):
+    resp = client.get("/api/salons/inactive-claimed-salon")
+    assert resp.status_code == 404
+
+
+def test_detail_missing_salon_still_404(client):
+    resp = client.get("/api/salons/does-not-exist")
+    assert resp.status_code == 404
+
+
+def test_detail_no_owner_identity_fields_exposed(client):
+    resp = client.get("/api/salons/claimed-salon")
+    body = resp.json()
+    for leaky_key in ("user_id", "owner_id", "owner", "owner_user_id", "salon_owners"):
+        assert leaky_key not in body
+
+
+def test_detail_ownership_check_is_embedded_not_a_separate_query(client):
+    # The detail endpoint already issues several queries pre-T-024 (lazy
+    # relationships: photos, hours, services, social_links, reviews — each
+    # accessed via SalonDetail.model_validate/len(salon.reviews)). T-024
+    # must not add a *separate* top-level query against salon_owners; the
+    # EXISTS is embedded as a subquery inside the main salon SELECT.
+    statements = _captured_statements(client, "/api/salons/claimed-salon")
+    # The one query that references salon_owners must be the main salon
+    # SELECT with an embedded EXISTS subquery, not a standalone one.
+    owner_referencing = [s for s in statements if "salon_owners" in s.lower()]
+    assert len(owner_referencing) == 1, f"expected exactly one statement referencing salon_owners, got {len(owner_referencing)}: {owner_referencing}"
+    assert "exists" in owner_referencing[0].lower()
+    assert "salons" in owner_referencing[0].lower()  # same statement also selects from salons
+
+
+# ── Map endpoint regression ──────────────────────────────────────────────────
+
+def test_map_response_unchanged_ten_fields(client):
+    resp = client.get("/api/salons/map")
+    assert resp.status_code == 200
+    body = resp.json()
+    assert isinstance(body, list)
+    if body:
+        assert "is_owner_claimed" not in body[0]
+        assert len(body[0]) == 10
