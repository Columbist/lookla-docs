diff --git a/crawler/beauty_crawler/log_redaction.py b/crawler/beauty_crawler/log_redaction.py
new file mode 100644
index 0000000..0312368
--- /dev/null
+++ b/crawler/beauty_crawler/log_redaction.py
@@ -0,0 +1,64 @@
+"""Logging hardening for the crawler/crawler_worker Celery processes.
+
+httpx (and httpcore, its transport layer) log the full request URL at
+INFO level by design. Some of this codebase's own outbound requests
+carry credentials directly in the URL (Telegram's Bot API embeds the
+token in the URL path; a Google Custom Search fallback in facebook.py
+passes its key as a query parameter) — Celery's own logging setup
+(driven by `--loglevel=info`) makes those loggers' output reach the
+container's logs. Two independent layers of defense are applied:
+
+1. Third-party HTTP client loggers are pinned to WARNING, so their
+   request-level INFO logging never fires in the first place.
+2. A redaction filter scrubs known credential shapes from any log
+   record that still reaches a handler, regardless of which logger
+   produced it — a backstop for exceptions/error messages that may
+   embed a credential-bearing URL even at WARNING/ERROR level.
+"""
+import logging
+import re
+
+NOISY_HTTP_LOGGERS = ("httpx", "httpcore", "urllib3", "requests")
+
+_PATTERNS = [
+    # Telegram bot token embedded in a URL path segment: /bot<id>:<secret>/
+    (re.compile(r"(/bot)\d+:[A-Za-z0-9_-]+"), r"\1<redacted>"),
+    # Credential-shaped query parameters (key=, api_key=, token=, access_token=)
+    (re.compile(r"([?&](?:key|api_key|token|access_token)=)[^&\s]+", re.IGNORECASE), r"\1<redacted>"),
+    # Authorization header values, if ever formatted into a log message
+    (re.compile(r"(Authorization[\"']?\s*[:=]\s*[\"']?)(?:Bearer\s+)?\S+", re.IGNORECASE), r"\1<redacted>"),
+    # user:password@ in redis://, rediss://, postgres(ql)(+driver):// URLs
+    (re.compile(r"((?:redis|rediss|postgres(?:ql)?(?:\+\w+)?)://[^:/\s@]*:)[^@\s]+(@)"), r"\1<redacted>\2"),
+]
+
+
+def redact(text: str) -> str:
+    for pattern, replacement in _PATTERNS:
+        text = pattern.sub(replacement, text)
+    return text
+
+
+class RedactingFilter(logging.Filter):
+    """Scrubs known credential shapes from the final formatted log message."""
+
+    def filter(self, record: logging.LogRecord) -> bool:
+        try:
+            message = record.getMessage()
+        except Exception:
+            return True
+        redacted = redact(message)
+        if redacted != message:
+            record.msg = redacted
+            record.args = ()
+        return True
+
+
+def harden_logger(logger: logging.Logger) -> None:
+    """Quiets noisy HTTP client loggers and attaches redaction to every
+    handler on the given logger. Idempotent — safe to call more than once
+    (Celery fires after_setup_logger/after_setup_task_logger per logger)."""
+    for name in NOISY_HTTP_LOGGERS:
+        logging.getLogger(name).setLevel(logging.WARNING)
+    for handler in logger.handlers:
+        if not any(isinstance(f, RedactingFilter) for f in handler.filters):
+            handler.addFilter(RedactingFilter())
