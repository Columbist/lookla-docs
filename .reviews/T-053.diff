diff --git a/crawler/beauty_crawler/test_log_redaction.py b/crawler/beauty_crawler/test_log_redaction.py
new file mode 100644
index 0000000..af7dfd5
--- /dev/null
+++ b/crawler/beauty_crawler/test_log_redaction.py
@@ -0,0 +1,131 @@
+"""T-053: proves credential shapes are scrubbed from log messages before
+they reach a handler, and that non-credential status messages pass through
+unchanged. Uses clearly fake tokens/passwords only."""
+import logging
+import unittest
+
+from .log_redaction import RedactingFilter, harden_logger, redact
+
+
+class RedactTelegramTokenTests(unittest.TestCase):
+    def test_bot_token_in_url_path_is_redacted(self):
+        msg = "HTTP Request: POST https://api.telegram.org/bot111222333:AAHexampleFakeToken0987654321zyx/sendMessage \"HTTP/1.1 200 OK\""
+        out = redact(msg)
+        self.assertNotIn("AAHexampleFakeToken", out)
+        self.assertIn("/bot<redacted>", out)
+
+    def test_multiple_distinct_token_shapes_are_all_redacted(self):
+        # Different bot IDs and different secret lengths/charsets — not a
+        # single-fixture regex that only happens to match one example.
+        cases = [
+            "https://api.telegram.org/bot123:short-Fake1/sendMessage",
+            "https://api.telegram.org/bot999999999:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA/sendMessage",
+            "https://api.telegram.org/bot1:a_b-C9zZ/getMe",
+        ]
+        for url in cases:
+            with self.subTest(url=url):
+                out = redact(url)
+                self.assertNotRegex(out, r"/bot\d+:[A-Za-z0-9_-]+")
+                self.assertIn("/bot<redacted>", out)
+
+
+class RedactQueryParamTests(unittest.TestCase):
+    def test_key_and_api_key_and_token_params_are_redacted(self):
+        cases = {
+            "https://www.googleapis.com/customsearch/v1?key=FAKEKEY123&cx=abc": "key=<redacted>",
+            "https://example.com/x?api_key=FAKESECRETXYZ&q=1": "api_key=<redacted>",
+            "https://example.com/x?token=FAKE.TOKEN.VALUE": "token=<redacted>",
+            "https://example.com/x?access_token=FAKEACCESS999": "access_token=<redacted>",
+        }
+        for url, expect_fragment in cases.items():
+            with self.subTest(url=url):
+                out = redact(url)
+                self.assertIn(expect_fragment, out)
+                self.assertNotIn("FAKEKEY123", out)
+                self.assertNotIn("FAKESECRETXYZ", out)
+                self.assertNotIn("FAKE.TOKEN.VALUE", out)
+                self.assertNotIn("FAKEACCESS999", out)
+
+
+class RedactAuthorizationHeaderTests(unittest.TestCase):
+    def test_bearer_authorization_header_is_redacted(self):
+        msg = "Authorization: Bearer FAKEBEARERTOKEN1234567890"
+        out = redact(msg)
+        self.assertNotIn("FAKEBEARERTOKEN1234567890", out)
+
+    def test_authorization_dict_style_is_redacted(self):
+        msg = "headers={'Authorization': 'FAKERAWKEYVALUE'}"
+        out = redact(msg)
+        self.assertNotIn("FAKERAWKEYVALUE", out)
+
+
+class RedactConnectionUrlTests(unittest.TestCase):
+    def test_redis_url_password_is_redacted(self):
+        msg = "Connected to redis://:FAKEREDISPASSWORD@redis:6379/0"
+        out = redact(msg)
+        self.assertNotIn("FAKEREDISPASSWORD", out)
+        self.assertIn("redis://:<redacted>@redis:6379/0", out)
+
+    def test_postgres_url_password_is_redacted(self):
+        msg = "postgresql+psycopg2://beauty:FAKEDBPASSWORD@db:5432/beauty_gr"
+        out = redact(msg)
+        self.assertNotIn("FAKEDBPASSWORD", out)
+        self.assertIn("postgresql+psycopg2://beauty:<redacted>@db:5432/beauty_gr", out)
+
+
+class SanitizedStatusMessagesPassThroughTests(unittest.TestCase):
+    def test_sanitized_success_message_is_unchanged(self):
+        msg = "Telegram request completed with HTTP 200"
+        self.assertEqual(redact(msg), msg)
+
+    def test_plain_informational_message_is_unchanged(self):
+        msg = "Daily Telegram report sent"
+        self.assertEqual(redact(msg), msg)
+
+
+class RedactingFilterTests(unittest.TestCase):
+    def _make_record(self, msg, args=()):
+        return logging.LogRecord(
+            name="httpx", level=logging.INFO, pathname=__file__, lineno=1,
+            msg=msg, args=args, exc_info=None,
+        )
+
+    def test_filter_scrubs_record_message_in_place(self):
+        record = self._make_record(
+            "HTTP Request: POST https://api.telegram.org/bot42:FAKETOKENVALUE/sendMessage \"HTTP/1.1 200 OK\""
+        )
+        result = RedactingFilter().filter(record)
+        self.assertTrue(result, "filter must never suppress the record, only scrub it")
+        self.assertNotIn("FAKETOKENVALUE", record.getMessage())
+
+    def test_filter_leaves_clean_records_untouched(self):
+        record = self._make_record("celery@worker ready.")
+        RedactingFilter().filter(record)
+        self.assertEqual(record.getMessage(), "celery@worker ready.")
+
+
+class HardenLoggerTests(unittest.TestCase):
+    def test_noisy_http_loggers_are_pinned_to_warning(self):
+        for name in ("httpx", "httpcore", "urllib3", "requests"):
+            logging.getLogger(name).setLevel(logging.DEBUG)
+
+        dummy = logging.getLogger("test-harden-logger")
+        dummy.handlers = [logging.StreamHandler()]
+        harden_logger(dummy)
+
+        for name in ("httpx", "httpcore", "urllib3", "requests"):
+            self.assertEqual(logging.getLogger(name).level, logging.WARNING)
+
+    def test_harden_logger_is_idempotent_no_duplicate_filters(self):
+        dummy = logging.getLogger("test-harden-logger-idempotent")
+        dummy.handlers = [logging.StreamHandler()]
+        harden_logger(dummy)
+        harden_logger(dummy)
+        filter_count = sum(
+            1 for f in dummy.handlers[0].filters if isinstance(f, RedactingFilter)
+        )
+        self.assertEqual(filter_count, 1)
+
+
+if __name__ == "__main__":
+    unittest.main()
