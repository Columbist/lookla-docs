@@ -0,0 +1,69 @@
+"""T-053: proves the logging changes did not alter send()/send_daily_report()
+behavior — same httpx call, same return semantics, same delivery outcome.
+No real network access; httpx.post is mocked."""
+import logging
+import unittest
+from unittest.mock import MagicMock, patch
+
+from . import telegram_notify
+
+
+class SendBehaviorUnchangedTests(unittest.TestCase):
+    def test_send_returns_false_when_credentials_missing(self):
+        with patch.object(telegram_notify, "BOT_TOKEN", ""), \
+             patch.object(telegram_notify, "CHAT_ID", "123"):
+            self.assertFalse(telegram_notify.send("hello"))
+
+    @patch("beauty_crawler.telegram_notify.httpx.post")
+    def test_send_posts_to_telegram_and_returns_true_on_success(self, mock_post):
+        mock_resp = MagicMock()
+        mock_resp.status_code = 200
+        mock_resp.raise_for_status.return_value = None
+        mock_post.return_value = mock_resp
+
+        with patch.object(telegram_notify, "BOT_TOKEN", "fake-token"), \
+             patch.object(telegram_notify, "CHAT_ID", "fake-chat-id"):
+            result = telegram_notify.send("test message")
+
+        self.assertTrue(result)
+        mock_post.assert_called_once()
+        _, kwargs = mock_post.call_args
+        self.assertEqual(kwargs["json"]["text"], "test message")
+        self.assertEqual(kwargs["json"]["chat_id"], "fake-chat-id")
+
+    @patch("beauty_crawler.telegram_notify.httpx.post")
+    def test_send_returns_false_and_logs_on_http_error(self, mock_post):
+        mock_post.side_effect = Exception("boom")
+        with patch.object(telegram_notify, "BOT_TOKEN", "fake-token"), \
+             patch.object(telegram_notify, "CHAT_ID", "fake-chat-id"):
+            result = telegram_notify.send("test message")
+        self.assertFalse(result)
+
+
+class SendDailyReportTruthfulLoggingTests(unittest.TestCase):
+    """T-053 also fixed send_daily_report() unconditionally logging
+    "sent" regardless of whether send() actually succeeded — verify the
+    log now reflects the real outcome, without changing what gets sent."""
+
+    @patch("beauty_crawler.telegram_notify.daily_report")
+    @patch("beauty_crawler.telegram_notify.send")
+    def test_logs_success_only_when_send_returns_true(self, mock_send, mock_report):
+        mock_report.return_value = "report text"
+        mock_send.return_value = True
+        with self.assertLogs(telegram_notify.logger, level="INFO") as cm:
+            telegram_notify.send_daily_report()
+        self.assertTrue(any("sent" in line for line in cm.output))
+        mock_send.assert_called_once_with("report text")
+
+    @patch("beauty_crawler.telegram_notify.daily_report")
+    @patch("beauty_crawler.telegram_notify.send")
+    def test_logs_warning_when_send_returns_false(self, mock_send, mock_report):
+        mock_report.return_value = "report text"
+        mock_send.return_value = False
+        with self.assertLogs(telegram_notify.logger, level="WARNING") as cm:
+            telegram_notify.send_daily_report()
+        self.assertTrue(any("not sent" in line for line in cm.output))
+
+
+if __name__ == "__main__":
+    unittest.main()
