# ──────────────────────────────────────────────────────────────
# Lookla — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ─────────────────────────────────────
DB_NAME=beauty_gr
DB_USER=beauty
DB_PASSWORD=CHANGE_ME_strong_password
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Backend / Security ───────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ALLOWED_ORIGINS=https://lookla.gr,https://www.lookla.gr
ENVIRONMENT=production

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Apple Sign In ─────────────────────────────────────────────
APPLE_CLIENT_ID=gr.lookla.app
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ── Media Storage (Cloudflare R2) ────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=lookla-media
R2_PUBLIC_URL=https://media.lookla.gr

# ── Email (Brevo) ─────────────────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@lookla.gr
BREVO_SENDER_NAME=Lookla
ADMIN_EMAIL=columb@europe.com

# ── Translations (DeepL) ─────────────────────────────────────
DEEPL_API_KEY=

# ── Content Moderation ────────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_VISION_API_KEY=

# ── Payments (Stripe) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYMENT_PROVIDER=stripe

# ── WhatsApp OTP (Meta) ───────────────────────────────────────
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=

# ── Cloudflare Turnstile ──────────────────────────────────────
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=

# ── Crawler (existing) ────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
